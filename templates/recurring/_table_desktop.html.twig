{% set freqMap = {daily: 'Diario', weekly: 'Semanal', monthly: 'Mensual', yearly: 'Anual'} %}
<table class="table table-hover align-middle mb-0">
	<thead style="--bs-table-bg: var(--bs-tertiary-bg);">
		<tr>
			<th class="text-muted small text-uppercase fw-normal">Nombre</th>
			<th class="text-muted small text-uppercase fw-normal">Descripción</th>
			<th class="text-muted small text-uppercase fw-normal">Tipo</th>
			<th class="text-muted small text-uppercase fw-normal text-end">Importe</th>
			<th class="text-muted small text-uppercase fw-normal">Frecuencia</th>
			<th class="text-muted small text-uppercase fw-normal">Día</th>
			<th class="text-muted small text-uppercase fw-normal">Categoría</th>
			<th class="text-muted small text-uppercase fw-normal">Estado</th>
			<th class="text-muted small text-uppercase fw-normal text-end">Acciones</th>
		</tr>
	</thead>
	<tbody>
		{% for recurring in recurrings %}
			<tr class="{{ not recurring.isActive ? 'text-muted' : '' }}">
				<td class="fw-semibold">{{ recurring.name }}</td>
				<td class="text-muted">
					{% if recurring.description %}
						{{ recurring.description|slice(0,8) }}
						{% if recurring.description|length > 8 %}…{% endif %}
					{% else %}—{% endif %}
				</td>
				<td>
					{% if recurring.type == 'expense' %}
						<span class="badge bg-danger-subtle text-danger">Gasto</span>
					{% else %}
						<span class="badge bg-success-subtle text-success">Ingreso</span>
					{% endif %}
				</td>
				<td class="text-end fw-semibold {{ recurring.type == 'expense' ? 'text-danger' : 'text-success' }}">
					{{ recurring.type == 'expense' ? '-' : '+' }}{{ recurring.amount|number_format(2, ',', '.') }} {{ currentAccount.currency }}
				</td>
				<td>{{ freqMap[recurring.frequency] ?? recurring.frequency }}</td>
				<td>{{ recurring.dayOfExecution }}</td>
				<td>
					{% if recurring.category %}
						<span class="d-inline-block rounded-circle me-1" style="width:8px;height:8px;background:{{ recurring.category.color }}"></span>
						<span class="small">{{ recurring.category.name }}</span>
					{% else %}
						<span class="small text-muted">—</span>
					{% endif %}
				</td>
				<td>
					{% if recurring.isActive %}
						<span class="badge bg-success-subtle text-success">Activa</span>
					{% else %}
						<span class="badge bg-secondary-subtle text-secondary">Inactiva</span>
					{% endif %}
				</td>
				<td class="text-end">
					<div class="d-inline-flex align-items-center gap-2">
						<div class="d-inline">
							<a href="{{ path('recurring_edit', {id: recurring.id}) }}"
							   class="btn btn-sm btn-outline-primary py-0 px-1"
							   data-bs-toggle="tooltip" data-bs-title="Editar" aria-label="Editar">
								<i class="fa-solid fa-pen fa-sm"></i>
							</a>
						</div>
						<form method="post" action="{{ path('recurring_toggle', {id: recurring.id}) }}" class="d-inline">
							<input type="hidden" name="_token" value="{{ csrf_token('toggle' ~ recurring.id) }}">
							<button type="submit"
							        class="btn btn-sm {{ recurring.isActive ? 'btn-outline-warning' : 'btn-outline-success' }} py-0"
									style="padding-left: 0.4rem; padding-right: 0.4rem;"
							        data-bs-toggle="tooltip" data-bs-title="{{ recurring.isActive ? 'Pausar' : 'Activar' }}"
							        aria-label="{{ recurring.isActive ? 'Pausar' : 'Activar' }}">
								<i class="fa-solid {{ recurring.isActive ? 'fa-pause' : 'fa-play' }} fa-sm"></i>
							</button>
						</form>
						{% set genCount = generatedCounts[recurring.id] ?? 0 %}
						<form method="post" action="{{ path('recurring_delete', {id: recurring.id}) }}" class="d-inline"
						      data-controller="confirm"
						      data-action="submit->confirm#submit"
						      data-confirm-message-value="¿Eliminar el movimiento recurrente «{{ recurring.name }}»? Esta acción no se puede deshacer.{% if genCount > 0 %} Si solo quieres detenerla, puedes pausarla o ponerle una fecha de fin.{% endif %}"
						      data-confirm-text-value="Eliminar"
						      {% if genCount > 0 %}
						      data-confirm-checkbox-label-value="Eliminar también {{ genCount == 1 ? 'el movimiento generado' : 'los ' ~ genCount ~ ' movimientos generados' }}"
						      data-confirm-checkbox-name-value="delete_generated"
						      {% endif %}>
							<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ recurring.id) }}">
							<button type="submit"
							        class="btn btn-sm btn-outline-danger py-0 px-1"
							        data-bs-toggle="tooltip" data-bs-title="Eliminar" aria-label="Eliminar">
								<i class="fa-solid fa-trash fa-sm"></i>
							</button>
						</form>
					</div>
				</td>
			</tr>
		{% else %}
			<tr>
				<td colspan="9" class="text-center text-muted py-4">No hay transacciones recurrentes.</td>
			</tr>
		{% endfor %}
	</tbody>
</table>

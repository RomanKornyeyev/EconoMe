{% set freqMap = {daily: 'Diario', weekly: 'Semanal', monthly: 'Mensual', yearly: 'Anual'} %}
<div class="p-3 d-flex flex-column gap-2">
    {% for recurring in recurrings %}
    <div class="bg-body-secondary rounded-3 p-3 {{ not recurring.isActive ? 'opacity-75' : '' }}">
        <div class="d-flex justify-content-between align-items-center mb-1">
            <span class="fw-semibold small">
                {{ recurring.name }}
                {% if recurring.type == 'expense' %}
                    <span class="badge bg-danger-subtle text-danger ms-1">Gasto</span>
                {% else %}
                    <span class="badge bg-success-subtle text-success ms-1">Ingreso</span>
                {% endif %}
            </span>
            <div class="d-flex align-items-center gap-2">
                <span class="fw-semibold {{ recurring.type == 'expense' ? 'text-danger' : 'text-success' }}">
                    {{ recurring.type == 'expense' ? '-' : '+' }}{{ recurring.amount|number_format(2, ',', '.') }}
                </span>
                <div class="dropdown">
                    <button class="btn btn-sm btn-outline-secondary text-muted text-decoration-none lh-1" data-bs-toggle="dropdown" aria-expanded="false">&#8942;</button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li>
                            <a class="dropdown-item" href="{{ path('recurring_edit', {id: recurring.id}) }}">
                                <i class="fa-solid fa-pen fa-sm me-2 text-muted"></i>Editar
                            </a>
                        </li>
                        <li>
                            <form method="post" action="{{ path('recurring_toggle', {id: recurring.id}) }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('toggle' ~ recurring.id) }}">
                                <button type="submit" class="dropdown-item">
                                    <i class="fa-solid {{ recurring.isActive ? 'fa-pause' : 'fa-play' }} fa-sm me-2 text-muted"></i>{{ recurring.isActive ? 'Pausar' : 'Activar' }}
                                </button>
                            </form>
                        </li>
                        <li>
                            <form method="post" action="{{ path('recurring_delete', {id: recurring.id}) }}"
                                  data-controller="confirm"
                                  data-action="submit->confirm#submit"
                                  data-confirm-message-value="¿Eliminar la recurrente «{{ recurring.name }}»? Esta acción no se puede deshacer."
                                  data-confirm-text-value="Eliminar">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ recurring.id) }}">
                                <button type="submit" class="dropdown-item text-danger">
                                    <i class="fa-solid fa-trash fa-sm me-2"></i>Eliminar
                                </button>
                            </form>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-1">
            <span class="text-muted" style="font-size:12px">
                <i class="fa-solid fa-rotate me-1"></i>{{ freqMap[recurring.frequency] ?? recurring.frequency }} · día {{ recurring.dayOfExecution }}
            </span>
            <div class="d-flex align-items-center gap-2">
                {% if recurring.category %}
                    <span style="font-size:12px" class="text-muted">
                        <span class="d-inline-block rounded-circle me-1" style="width:6px;height:6px;background:{{ recurring.category.color }}"></span>
                        {{ recurring.category.name }}
                    </span>
                {% endif %}
                {% if recurring.isActive %}
                    <span class="badge bg-success-subtle text-success">Activa</span>
                {% else %}
                    <span class="badge bg-secondary-subtle text-secondary">Inactiva</span>
                {% endif %}
            </div>
        </div>
    </div>
    {% else %}
        <p class="text-center text-muted py-4 mb-0">No hay transacciones recurrentes.</p>
    {% endfor %}
</div>

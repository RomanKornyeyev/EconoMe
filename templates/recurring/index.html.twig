{% extends 'base.html.twig' %}

{% block title %}Transacciones recurrentes{% endblock %}

{% block content %}
{% set canEdit = is_granted('ACCOUNT_EDIT', currentAccount) %}
<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="{{ path('transaction_index', {account: currentAccount.id}) }}">Movimientos</a></li>
        <li class="breadcrumb-item active" aria-current="page">Recurrentes</li>
    </ol>
</nav>

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <div class="d-flex align-items-center gap-2">
        <h4 class="mb-0">
            {# <i class="fa-solid fa-rotate me-2"></i> #}
            Movimientos recurrentes
        </h4>
        {% if accounts|length > 1 %}
            <div class="btn-group" role="group">
                <button type="button" class="btn btn-sm btn-outline-primary dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
                    {{ currentAccount.name }}
                </button>
                <ul class="dropdown-menu">
                    {% for acc in accounts %}
                        <li><a class="dropdown-item {{ acc.id == currentAccount.id ? 'active' : '' }}" href="?account={{ acc.id }}">{{ acc.name }}</a></li>
                    {% endfor %}
                </ul>
            </div>
        {% endif %}
    </div>
    {% if canEdit %}
    <a href="{{ path('recurring_create', {account: currentAccount.id}) }}" class="btn btn-primary btn-sm">
        <i class="fa-solid fa-plus me-1"></i>Nueva recurrente
    </a>
    {% endif %}
</div>

{% if recurrings is empty %}
    <div class="text-center py-5">
        <i class="fa-solid fa-rotate fa-3x text-muted mb-3"></i>
        <h5 class="text-muted">No hay transacciones recurrentes</h5>
        {% if canEdit %}
        <a href="{{ path('recurring_create', {account: currentAccount.id}) }}" class="btn btn-primary mt-2">
            <i class="fa-solid fa-plus me-1"></i>Crear primera recurrente
        </a>
        {% endif %}
    </div>
{% else %}
    <div class="card border shadow-sm">
        <div class="card-header bg-body-tertiary border-bottom">
            <span class="text-muted small">
                {{ recurrings|length }} {{ recurrings|length == 1 ? 'recurrente' : 'recurrentes' }}
            </span>
        </div>

        {# Tabla desktop: visible en md+ #}
        <div class="d-none d-md-block table-responsive">
            {% include 'recurring/_table_desktop.html.twig' %}
        </div>

        {# Cards mobile: visible en < md #}
        <div class="d-md-none">
            {% include 'recurring/_cards_mobile.html.twig' %}
        </div>
    </div>
{% endif %}
{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}Nuevo movimiento recurrente{% endblock %}

{% block content %}
<div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-6">
        <div class="mb-4">
            <a href="{{ path('recurring_index', {account: account.id}) }}" class="btn btn-outline-secondary">
                <i class="fa-solid fa-arrow-left me-1"></i>Volver
            </a>
        </div>

        <div class="card border-0 shadow bg-body-tertiary">
            {{ form_start(form, {attr: {class: 'needs-validation'}}) }}
                <div class="card-header bg-transparent border-bottom py-3 px-4">
                    <h5 class="mb-0">Nuevo movimiento recurrente</h5>
                    <small class="text-muted">{{ account.name }}</small>
                </div>
                <div class="card-body p-4">
                    {% include 'recurring/_form_recurring.html.twig' %}
                </div>
                <div class="card-footer bg-transparent border-top d-flex gap-2 justify-content-center py-3">
                    <button type="submit" class="btn btn-primary">
                        <i class="fa-solid fa-check me-1"></i>Guardar
                    </button>
                </div>
            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}Nueva recurrente{% endblock %}

{% block content %}
<div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-6">
        <div class="d-flex align-items-center gap-2 mb-4">
            <a href="{{ path('recurring_index', {account: account.id}) }}" class="btn btn-sm btn-outline-secondary">
                <i class="fa-solid fa-arrow-left"></i>
            </a>
            <div>
                <h4 class="mb-0">Nueva transacción recurrente</h4>
                <small class="text-muted">{{ account.name }}</small>
            </div>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                {{ form_start(form) }}
                    {{ form_row(form.name) }}
                    {{ form_row(form.type) }}
                    {{ form_row(form.amount) }}
                    {{ form_row(form.frequency) }}
                    {{ form_row(form.dayOfExecution) }}
                    {{ form_row(form.category) }}
                    <div class="row g-3">
                        <div class="col-6">{{ form_row(form.startDate) }}</div>
                        <div class="col-6">{{ form_row(form.endDate) }}</div>
                    </div>
                    <div class="d-flex gap-2 mt-3">
                        <button type="submit" class="btn btn-primary">
                            <i class="fa-solid fa-check me-1"></i>Crear
                        </button>
                        <a href="{{ path('recurring_index', {account: account.id}) }}" class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}

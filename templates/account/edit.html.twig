{% extends 'base.html.twig' %}

{% block title %}Editar cuenta{% endblock %}

{% block content %}
<div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-6">
        <div class="d-flex align-items-center gap-2 mb-4">
            <a href="{{ path('account_show', {id: account.id}) }}" class="btn btn-sm btn-outline-secondary">
                <i class="fa-solid fa-arrow-left"></i>
            </a>
            <h4 class="mb-0">Editar cuenta</h4>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                {{ form_start(form) }}
                    {{ form_row(form.name) }}
                    {{ form_row(form.description) }}
                    <div class="row g-3">
                        <div class="col-8">{{ form_row(form.currency) }}</div>
                        <div class="col-4">{{ form_row(form.color) }}</div>
                    </div>
                    <div class="d-flex gap-2 mt-3">
                        <button type="submit" class="btn btn-primary">
                            <i class="fa-solid fa-check me-1"></i>Guardar cambios
                        </button>
                        <a href="{{ path('account_show', {id: account.id}) }}" class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}{{ isNew ? 'Nueva cuenta' : 'Editar cuenta' }}{% endblock %}

{% block content %}
<div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-6">
        <div class="mb-4">
            <a href="{{ isNew ? path('account_index') : path('account_show', {id: account.id}) }}" class="btn btn-outline-secondary">
                <i class="fa-solid fa-arrow-left me-1"></i>Volver
            </a>
        </div>

        <div class="card border-0 shadow bg-body-tertiary">
            {{ form_start(form, {attr: {class: 'needs-validation'}}) }}
                <div class="card-header bg-transparent border-bottom py-3 px-4">
                    <h5 class="mb-0">{{ isNew ? 'Nueva cuenta' : 'Editar cuenta' }}</h5>
                    {% if not isNew %}
                        <small class="text-muted">{{ account.name }}</small>
                    {% endif %}
                </div>
                <div class="card-body p-4">
                    {{ form_row(form.name) }}
                    {{ form_row(form.description) }}
                    <div class="row g-3">
                        <div class="col-md-6">{{ form_row(form.currency) }}</div>
                        <div class="col-md-6">{{ form_row(form.color) }}</div>
                    </div>
                    {% if form.copyTemplates is defined %}
                        <hr class="my-3">
                        <div class="row g-3">
                            <div class="d-flex align-items-start gap-2">
                                <div class="form-check form-switch mb-0 ps-4">
                                    {{ form_widget(form.copyTemplates, {attr: {class: 'form-check-input', role: 'switch'}}) }}
                                    {{ form_label(form.copyTemplates, null, {label_attr: {class: 'form-check-label'}}) }}
                                </div>
                                <button type="button"
                                        class="btn btn-sm btn-outline-info rounded-circle d-inline-flex align-items-center justify-content-center p-0"
                                        style="width:1.6rem;height:1.6rem;"
                                        data-bs-toggle="popover"
                                        data-bs-trigger="focus"
                                        data-bs-placement="top"
                                        data-bs-content="Si lo desmarcas, la cuenta empezará sin categorías y podrás crearlas después."
                                        aria-label="Más información sobre las categorías">
                                    <i class="fa-solid fa-info"></i>
                                </button>
                            </div>
                        </div>
                    {% endif %}
                </div>
                <div class="card-footer bg-transparent border-top d-flex gap-2 justify-content-center py-3">
                    <button type="submit" class="btn btn-primary">
                        <i class="fa-solid fa-check me-1"></i>{{ isNew ? 'Crear cuenta' : 'Guardar cambios' }}
                    </button>
                </div>
            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}

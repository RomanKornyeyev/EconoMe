{% extends 'base.html.twig' %}

{% block title %}{{ account.name }}{% endblock %}

{% block content %}
<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <div class="d-flex align-items-center gap-3">
        <a href="{{ path('account_index') }}" class="btn btn-sm btn-outline-secondary">
            <i class="fa-solid fa-arrow-left"></i>
        </a>
        <div>
            <h4 class="mb-0">{{ account.name }}</h4>
            {% if account.description %}
                <small class="text-muted">{{ account.description }}</small>
            {% endif %}
        </div>
    </div>
    <div class="d-flex gap-2">
        {% if currentMember and currentMember.canManageAccount() %}
            <a href="{{ path('account_edit', {id: account.id}) }}" class="btn btn-sm btn-outline-primary">
                <i class="fa-solid fa-pen me-1"></i>Editar
            </a>
            <a href="{{ path('category_index', {account: account.id}) }}" class="btn btn-sm btn-outline-primary">
                <i class="fa-solid fa-tags me-1"></i>Editar categorías
            </a>
        {% endif %}
        <a href="{{ path('transaction_index', {account: account.id}) }}" class="btn btn-sm btn-primary">
            <i class="fa-solid fa-arrow-right-arrow-left me-1"></i>Movimientos
        </a>
    </div>
</div>

{# Acciones rápidas #}
{# <div class="d-flex flex-wrap gap-2 mb-4">
    <a href="{{ path('dashboard', {account: account.id}) }}" class="btn btn-sm btn-outline-secondary">
        <i class="fa-solid fa-chart-line me-1"></i>Dashboard
    </a>
    <a href="{{ path('transaction_index', {account: account.id}) }}" class="btn btn-sm btn-outline-secondary">
        <i class="fa-solid fa-arrow-right-arrow-left me-1"></i>Movimientos
    </a> 
    <a href="{{ path('category_index', {account: account.id}) }}" class="btn btn-sm btn-outline-secondary">
        <i class="fa-solid fa-tags me-1"></i>Categorías asociadas
    </a> 
    <a href="{{ path('recurring_index', {account: account.id}) }}" class="btn btn-sm btn-outline-secondary">
        <i class="fa-solid fa-rotate me-1"></i>Recurrentes
    </a>
</div> #}

{# Balance #}
<div class="row g-3 mb-4">
    <div class="col-12 col-md-4">
        <div class="bg-body-secondary rounded-3 p-3 text-center">
            <div class="text-muted small text-uppercase mb-1">Saldo actual</div>
            <div class="fs-5 fw-semibold {{ balance >= 0 ? 'text-success' : 'text-danger' }}">
                {{ balance|number_format(2, ',', '.') }} {{ account.currency }}
            </div>
        </div>
    </div>
    <div class="col-12 col-md-4">
        <div class="bg-body-secondary rounded-3 p-3 text-center">
            <div class="text-muted small text-uppercase mb-1">Moneda</div>
            <div class="fs-5 fw-semibold">{{ account.currency }}</div>
        </div>
    </div>
    <div class="col-12 col-md-4">
        <div class="bg-body-secondary rounded-3 p-3 text-center">
            <div class="text-muted small text-uppercase mb-1">Miembros activos</div>
            <div class="fs-5 fw-semibold">{{ members|length }}</div>
        </div>
    </div>
</div>

{# Members #}
<div class="card border shadow-sm mb-4 bg-body-tertiary">
    <div class="card-header bg-transparent d-flex justify-content-between align-items-center py-3">
        <h5 class="mb-0 fw-semibold">
            Miembros
            <span class="badge rounded-pill bg-secondary align-middle ms-1">{{ members|length }}</span>
        </h5>
        {% if currentMember and currentMember.canManageAccount() %}
            <button type="button" class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#inviteMemberModal">
                <i class="fa-solid fa-user-plus me-1"></i>Invitar
            </button>
        {% endif %}
    </div>
    <div class="card-body p-0">
        <ul class="list-group list-group-flush">
            {% for member in members %}
                <li class="list-group-item d-flex align-items-center justify-content-between">
                    <div class="d-flex align-items-center gap-2">
                        <img src="{{ asset(member.user.profilePhoto) }}" class="rounded-circle" width="32" height="32" style="object-fit:cover" alt="">
                        <div>
                            <div class="fw-semibold">{{ member.user.nickname }}</div>
                            <small class="text-muted">{{ member.user.email }}</small>
                        </div>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <span class="badge {% if member.role == 'owner' %}bg-primary text-dark{% elseif member.role == 'editor' %}bg-info text-dark{% else %}bg-secondary{% endif %}">
                            {{ member.role }}
                        </span>
                        {% if currentMember and currentMember.canManageAccount() and member.user != app.user %}
                            <form method="post" action="{{ path('account_remove_member', {id: account.id, userId: member.user.id}) }}"
                                  onsubmit="return confirm('¿Eliminar a {{ member.user.nickname }} de la cuenta?')">
                                <input type="hidden" name="_token" value="{{ csrf_token('remove' ~ member.user.id) }}">
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    <i class="fa-solid fa-xmark"></i>
                                </button>
                            </form>
                        {% endif %}
                    </div>
                </li>
            {% endfor %}
        </ul>

        {% if pendingInvitations is not empty %}
            <div class="px-3 pt-3 pb-1">
                <small class="text-muted text-uppercase fw-semibold">Invitaciones pendientes</small>
            </div>
            <ul class="list-group list-group-flush">
                {% for invitation in pendingInvitations %}
                    <li class="list-group-item d-flex align-items-center justify-content-between">
                        <div class="d-flex align-items-center gap-2">
                            <img src="{{ asset(invitation.invitee.profilePhoto) }}" class="rounded-circle" width="32" height="32" style="object-fit:cover;opacity:.7" alt="">
                            <div>
                                <div class="fw-semibold">{{ invitation.invitee.nickname }}</div>
                                <small class="text-muted">{{ invitation.invitee.email }}</small>
                            </div>
                        </div>
                        <div class="d-flex align-items-center gap-2">
                            <span class="badge bg-body-secondary text-body-secondary">
                                <i class="fa-solid fa-clock me-1"></i>Pendiente · {{ invitation.role }}
                            </span>
                            {% if currentMember and currentMember.canManageAccount() %}
                                <form method="post" action="{{ path('account_invitation_cancel', {id: invitation.id}) }}"
                                      onsubmit="return confirm('¿Cancelar la invitación a {{ invitation.invitee.nickname }}?')">
                                    <input type="hidden" name="_token" value="{{ csrf_token('invitation_' ~ invitation.id) }}">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="fa-solid fa-xmark"></i>
                                    </button>
                                </form>
                            {% endif %}
                        </div>
                    </li>
                {% endfor %}
            </ul>
        {% endif %}
    </div>
</div>

{# Invite member modal (managers only) #}
{% if currentMember and currentMember.canManageAccount() %}
    <div class="modal fade" id="inviteMemberModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content bg-body-tertiary">
                <div class="modal-header">
                    <h5 class="modal-title">Invitar miembro</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4"
                     data-controller="user-search"
                     data-user-search-url-value="{{ path('account_invite_search', {id: account.id}) }}">
                    <label class="form-label small text-muted">Busca por nombre, apodo o email</label>
                    <input type="text"
                           class="form-control"
                           placeholder="Escribe al menos 2 caracteres…"
                           autocomplete="off"
                           data-user-search-target="input"
                           data-action="input->user-search#search">
                    <div class="mt-2" data-user-search-target="results"></div>
                </div>
            </div>
        </div>
    </div>
{% endif %}

{# Danger zone #}
<div class="card border-danger border-opacity-25 mb-4">
    <div class="card-header text-danger bg-transparent">
        <h6 class="mb-0"><i class="fa-solid fa-triangle-exclamation me-2"></i>Zona de peligro</h6>
    </div>
    <div class="card-body d-flex flex-wrap gap-2">
        {% if currentMember and not currentMember.isOwner() %}
            <form method="post" action="{{ path('account_leave', {id: account.id}) }}"
                  onsubmit="return confirm('¿Seguro que quieres abandonar esta cuenta?')">
                <input type="hidden" name="_token" value="{{ csrf_token('leave' ~ account.id) }}">
                <button type="submit" class="btn btn-sm btn-outline-danger">
                    <i class="fa-solid fa-right-from-bracket me-1"></i>Abandonar cuenta
                </button>
            </form>
        {% endif %}
        {% if currentMember and currentMember.isOwner() %}
            <form method="post" action="{{ path('account_delete', {id: account.id}) }}"
                  onsubmit="return confirm('¿Eliminar esta cuenta y todos sus datos? Esta acción no se puede deshacer.')">
                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ account.id) }}">
                <button type="submit" class="btn btn-sm btn-danger">
                    <i class="fa-solid fa-trash me-1"></i>Eliminar cuenta
                </button>
            </form>
        {% endif %}
    </div>
</div>
{% endblock %}

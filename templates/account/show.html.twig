{% extends 'base.html.twig' %}

{% block title %}{{ account.name }}{% endblock %}

{% block content %}
{% import 'partials/macros/_tour.html.twig' as tour %}

<div {{ tour.attrs('accounts') }}>

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <div class="d-flex align-items-center gap-3">
        <a href="{{ path('account_index') }}" class="btn btn-sm btn-outline-secondary">
            <i class="fa-solid fa-arrow-left"></i>
        </a>
        <div class="d-flex align-items-center gap-2 flex-wrap">
            <h1 class="mb-0 h3">Detalles de la cuenta</h1>
            {% include 'partials/_account_selector.html.twig' with {
                accounts: accounts,
                current: account,
                route: 'account_show',
                routeParam: 'id',
                tourStep: 1,
                tourTitle: 'Selector de cuenta',
                tourText: 'Aquí eliges la cuenta que quieres gestionar. Toda la información de esta página pertenece a la cuenta seleccionada.',
            } only %}
        </div>
    </div>
    <div class="d-flex gap-2">
        <a href="{{ path('dashboard', {account: account.id}) }}" class="btn btn-sm btn-outline-primary">
            <i class="fa-solid fa-chart-line me-1"></i>Dashboard
        </a>
        <a href="{{ path('transaction_index', {account: account.id}) }}" class="btn btn-sm btn-primary"
           data-tour-step="6"
           data-tour-title="Empieza a registrar"
           data-tour-text="Cuando quieras, entra aquí para añadir tus primeros movimientos a esta cuenta.">
            <i class="fa-solid fa-arrow-right-arrow-left me-1"></i>Movimientos
        </a>
        {{ tour.help_button() }}
    </div>
</div>

{# Balance #}
<div class="row g-3 mb-4"
     data-tour-step="2"
     data-tour-title="Resumen de la cuenta"
     data-tour-text="El saldo actual y los totales de movimientos y recurrentes activos. Las tarjetas son accesos directos a cada sección.">
    <div class="col-12 col-md-4">
        <div class="bg-body-secondary rounded-3 p-3 text-center">
            <div class="text-muted small text-uppercase mb-1">Saldo actual</div>
            <div class="fs-5 fw-semibold {{ balance >= 0 ? 'text-success' : 'text-danger' }}">
                {{ balance|number_format(2, ',', '.') }} {{ account.currency }}
            </div>
        </div>
    </div>
    <div class="col-12 col-md-4">
        <a href="{{ path('transaction_index', {account: account.id}) }}" class="d-block bg-body-secondary rounded-3 p-3 text-center text-decoration-none">
            <div class="text-muted small text-uppercase mb-1">Movimientos</div>
            <div class="fs-5 fw-semibold text-body">{{ transactionCount }}</div>
        </a>
    </div>
    <div class="col-12 col-md-4">
        <a href="{{ path('recurring_index', {account: account.id}) }}" class="d-block bg-body-secondary rounded-3 p-3 text-center text-decoration-none">
            <div class="text-muted small text-uppercase mb-1">Movimientos periódicos activos</div>
            <div class="fs-5 fw-semibold text-body">{{ activeRecurrings }}</div>
        </a>
    </div>
</div>

{# Información de la cuenta y categorías #}
<div class="row g-3 mb-4">
    <div class="col-12 col-lg-6"
         data-tour-step="4"
         data-tour-title="Datos de la cuenta"
         data-tour-text="El nombre, la descripción y el color de la cuenta. Con «Editar cuenta» puedes cambiarlos cuando quieras.">
        <div class="card border shadow-sm h-100 bg-body-tertiary">
            <div class="card-body">
                <div class="d-flex align-items-center gap-3 mb-3">
                    <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0"
                         style="width:52px;height:52px;background-color:{{ account.color ?? '#6c757d' }}20;border:2px solid {{ account.color ?? '#6c757d' }}">
                        <i class="fa-solid fa-wallet fa-lg" style="color:{{ account.color ?? '#6c757d' }}"></i>
                    </div>
                    <div class="min-w-0">
                        <h5 class="mb-0 fw-semibold text-truncate">{{ account.name }}</h5>
                        {% if account.description %}
                            <small class="text-muted text-truncate d-block">{{ account.description }}</small>
                        {% else %}
                            <small class="text-muted fst-italic">Sin descripción</small>
                        {% endif %}
                    </div>
                </div>

                <div class="d-flex flex-wrap gap-2">
                    <span class="badge bg-body-secondary text-body-secondary">
                        <i class="fa-regular fa-calendar me-1"></i>Creada el {{ account.createdAt ? account.createdAt|date('d/m/Y') : '—' }}
                    </span>
                </div>
            </div>
            {% if currentMember and currentMember.canManageAccount() %}
                <div class="card-footer bg-transparent d-flex justify-content-end">
                    <a href="{{ path('account_edit', {id: account.id}) }}" class="btn btn-primary">
                        Editar cuenta
                    </a>
                </div>
            {% endif %}
        </div>
    </div>

    <div class="col-12 col-lg-6"
         data-tour-step="3"
         data-tour-title="Categorías de la cuenta"
         data-tour-text="Cada cuenta tiene su propio juego de categorías para clasificar gastos e ingresos. Desde aquí las gestionas.">
        <div class="card border shadow-sm h-100 bg-body-tertiary">
            <div class="card-body">
                <div class="d-flex align-items-center gap-3 mb-3">
                    <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0 bg-body-secondary"
                         style="width:52px;height:52px;">
                        <i class="fa-solid fa-tags fa-lg text-body-secondary"></i>
                    </div>
                    <div class="min-w-0">
                        {% set categoryCount = categoryIncomeCount + categoryExpenseCount %}
                        <h5 class="mb-0 fw-semibold">Categorías</h5>
                        <small class="text-muted">
                            {{ categoryCount }} en total 
                            (
                                <span class="text-success">{{ categoryIncomeCount }} de ingresos</span>,
                                <span class="text-danger">{{ categoryExpenseCount }} de gastos</span>
                            )
                        </small>
                    </div>
                </div>
                <p class="text-muted mb-0">Ver y modificar las categorías asociadas a esta cuenta.</p>
            </div>
            {% if currentMember and currentMember.canManageAccount() %}
                <div class="card-footer bg-transparent d-flex justify-content-end">
                    <a href="{{ path('category_index', {account: account.id}) }}" class="btn btn-outline-primary">
                        Editar categorías
                    </a>
                </div>
            {% endif %}
        </div>
    </div>
</div>

{# Members #}
<div class="card border shadow-sm mb-4 bg-body-tertiary"
     data-tour-step="5"
     data-tour-title="Comparte la cuenta"
     data-tour-text="Puedes invitar a tus amigos a esta cuenta como editores o solo lectores. Ideal para gastos compartidos."
     data-tour-side="top">
    <div class="card-header bg-transparent d-flex justify-content-between align-items-center py-3">
        <h5 class="mb-0 fw-semibold">
            Miembros
            <span class="badge rounded-pill bg-secondary align-middle ms-1">{{ members|length }}</span>
        </h5>
        {% if currentMember and currentMember.canManageAccount() %}
            <button type="button" class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#inviteMemberModal">
                <i class="fa-solid fa-user-plus me-1"></i>Invitar
            </button>
        {% endif %}
    </div>
    <div class="card-body p-0">
        <ul class="list-group list-group-flush">
            {% for member in members %}
                <li class="list-group-item d-flex align-items-center justify-content-between bg-body-tertiary">
                    <div class="d-flex align-items-center gap-2">
                        <img src="{{ asset(member.user.profilePhoto) }}" class="rounded-circle" width="32" height="32" style="object-fit:cover" alt="">
                        <div>
                            <div class="fw-semibold">{{ member.user.nickname }}</div>
                            <small class="text-muted">{{ member.user.email }}</small>
                        </div>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <span class="badge {% if member.role == 'owner' %}bg-primary text-dark{% elseif member.role == 'editor' %}bg-info text-dark{% else %}bg-secondary{% endif %}">
                            {{ member.role|capitalize }}
                        </span>
                        {% if currentMember and currentMember.canManageAccount() and member.user != app.user %}
                            <form method="post" action="{{ path('account_remove_member', {id: account.id, userId: member.user.id}) }}"
                                  data-controller="confirm"
                                  data-action="submit->confirm#submit"
                                  data-confirm-message-value="¿Eliminar a {{ member.user.nickname }} de la cuenta?"
                                  data-confirm-text-value="Eliminar">
                                <input type="hidden" name="_token" value="{{ csrf_token('remove' ~ member.user.id) }}">
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    <i class="fa-solid fa-xmark"></i>
                                </button>
                            </form>
                        {% endif %}
                    </div>
                </li>
            {% endfor %}
        </ul>

        {% if pendingInvitations is not empty %}
            <div class="px-3 pt-3 pb-1">
                <small class="text-muted text-uppercase fw-semibold">Invitaciones pendientes</small>
            </div>
            <ul class="list-group list-group-flush">
                {% for invitation in pendingInvitations %}
                    <li class="list-group-item d-flex align-items-center justify-content-between">
                        <div class="d-flex align-items-center gap-2">
                            <img src="{{ asset(invitation.invitee.profilePhoto) }}" class="rounded-circle" width="32" height="32" style="object-fit:cover;opacity:.7" alt="">
                            <div>
                                <div class="fw-semibold">{{ invitation.invitee.nickname }}</div>
                                <small class="text-muted">{{ invitation.invitee.email }}</small>
                            </div>
                        </div>
                        <div class="d-flex align-items-center gap-2">
                            <span class="badge bg-body-secondary text-body-secondary">
                                <i class="fa-solid fa-clock me-1"></i>Pendiente · {{ invitation.role }}
                            </span>
                            {% if currentMember and currentMember.canManageAccount() %}
                                <form method="post" action="{{ path('account_invitation_cancel', {id: invitation.id}) }}"
                                      data-controller="confirm"
                                      data-action="submit->confirm#submit"
                                      data-confirm-message-value="¿Cancelar la invitación a {{ invitation.invitee.nickname }}?"
                                      data-confirm-text-value="Cancelar invitación">
                                    <input type="hidden" name="_token" value="{{ csrf_token('invitation_' ~ invitation.id) }}">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="fa-solid fa-xmark"></i>
                                    </button>
                                </form>
                            {% endif %}
                        </div>
                    </li>
                {% endfor %}
            </ul>
        {% endif %}
    </div>
</div>

{# Invite member modal (managers only) #}
{% if currentMember and currentMember.canManageAccount() %}
    <div class="modal fade" id="inviteMemberModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content bg-body-tertiary">
                <div class="modal-header">
                    <h5 class="modal-title">Invitar miembro</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4"
                     data-controller="user-search"
                     data-user-search-url-value="{{ path('account_invite_search', {id: account.id}) }}">
                    <label class="form-label small text-muted">Busca entre tus amigos por nombre, apodo o email</label>
                    <input type="text"
                           class="form-control"
                           placeholder="Escribe al menos 2 caracteres…"
                           autocomplete="off"
                           data-user-search-target="input"
                           data-action="input->user-search#search">
                    <div class="mt-2" data-user-search-target="results"></div>
                </div>
            </div>
        </div>
    </div>
{% endif %}

{# Danger zone #}
<div class="card border shadow-sm mb-4 bg-body-tertiary">
    <div class="card-header bg-transparent py-3">
        <h5 class="mb-0 fw-semibold">Zona de peligro</h5>
    </div>
    <div class="card-body">
        {% if currentMember and not currentMember.isOwner() %}
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
                <div class="min-w-0">
                    <div class="fw-semibold">Abandonar la cuenta</div>
                    <small class="text-muted">Dejarás de tener acceso a sus movimientos. Podrás volver si te invitan de nuevo.</small>
                </div>
                <form method="post" action="{{ path('account_leave', {id: account.id}) }}"
                      data-controller="confirm"
                      data-action="submit->confirm#submit"
                      data-confirm-message-value="¿Seguro que quieres abandonar «{{ account.name }}»?"
                      data-confirm-text-value="Abandonar">
                    <input type="hidden" name="_token" value="{{ csrf_token('leave' ~ account.id) }}">
                    <button type="submit" class="btn btn-sm btn-outline-danger">
                        <i class="fa-solid fa-right-from-bracket me-1"></i>Abandonar
                    </button>
                </form>
            </div>
        {% endif %}
        {% if currentMember and currentMember.isOwner() %}
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
                <div class="min-w-0">
                    <div class="fw-semibold">Eliminar la cuenta</div>
                    <small class="text-muted">
                        Se borrarán la cuenta y todos sus movimientos.
                        <span class="text-danger">Esta acción no se puede deshacer.</span>
                    </small>
                </div>
                <form method="post" action="{{ path('account_delete', {id: account.id}) }}"
                      data-controller="confirm"
                      data-action="submit->confirm#submit"
                      data-confirm-message-value="Se eliminará «{{ account.name }}» y todos sus datos de forma permanente. Esta acción no se puede deshacer."
                      data-confirm-text-value="Eliminar cuenta">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ account.id) }}">
                    <button type="submit" class="btn btn-sm btn-danger">
                        <i class="fa-solid fa-trash me-1"></i>Eliminar
                    </button>
                </form>
            </div>
        {% endif %}
    </div>
</div>

</div> {# /tour #}
{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}Mis cuentas{% endblock %}

{% block content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0"><i class="fa-solid fa-wallet me-2"></i>Mis cuentas</h4>
    <a href="{{ path('account_create') }}" class="btn btn-primary btn-sm">
        <i class="fa-solid fa-plus me-1"></i>Nueva cuenta
    </a>
</div>

{% if accounts is empty %}
    <div class="text-center py-5">
        <i class="fa-solid fa-wallet fa-3x text-muted mb-3"></i>
        <h5 class="text-muted">No tienes ninguna cuenta</h5>
        <p class="text-muted">Crea tu primera cuenta para empezar a registrar movimientos.</p>
        <a href="{{ path('account_create') }}" class="btn btn-primary">
            <i class="fa-solid fa-plus me-1"></i>Crear cuenta
        </a>
    </div>
{% else %}
    <div class="row g-3">
        {% for account in accounts %}
            <div class="col-12 col-md-6 col-xl-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <div class="rounded-circle d-flex align-items-center justify-content-center"
                                 style="width:44px;height:44px;background-color:{{ account.color ?? '#6c757d' }}20;border:2px solid {{ account.color ?? '#6c757d' }}">
                                <i class="fa-solid fa-wallet" style="color:{{ account.color ?? '#6c757d' }}"></i>
                            </div>
                            <div class="flex-grow-1 min-w-0">
                                <h6 class="mb-0 text-truncate">{{ account.name }}</h6>
                                {% if account.description %}
                                    <small class="text-muted text-truncate d-block">{{ account.description }}</small>
                                {% endif %}
                            </div>
                        </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="badge bg-body-secondary text-body-secondary">{{ account.currency }}</span>
                            <span class="badge bg-body-secondary text-body-secondary">
                                {{ account.activeMembers|length }} miembro{{ account.activeMembers|length != 1 ? 's' : '' }}
                            </span>
                        </div>
                    </div>
                    <div class="card-footer bg-transparent border-top-0">
                        <a href="{{ path('account_show', {id: account.id}) }}" class="btn btn-sm btn-outline-primary w-100">
                            Ver cuenta
                        </a>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>
{% endif %}
{% endblock %}

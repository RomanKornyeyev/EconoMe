{#
  Partial AJAX: resultados de búsqueda de usuarios para invitar a la cuenta.
  Inyectado por user_search_controller.js en el target "results".

  Variables:
    - account: Account
    - results: User[]
#}
{% if results|length == 0 %}
    <p class="text-muted small mb-0 py-2 px-1">
        No se encontró ningún amigo con ese nombre.<br>
        Solo puedes invitar a tus amigos. <a href="{{ path('app_friends_index') }}">Gestionar amigos</a>
    </p>
{% else %}
    <ul class="list-group list-group-flush">
        {% for user in results %}
            <li class="list-group-item bg-transparent px-1 py-2">
                <form method="post" action="{{ path('account_invite', {id: account.id}) }}"
                      class="d-flex align-items-center gap-2">
                    <input type="hidden" name="_token" value="{{ csrf_token('invite' ~ account.id) }}">
                    <input type="hidden" name="user_id" value="{{ user.id }}">
                    <img src="{{ asset(user.profilePhoto) }}" class="rounded-circle flex-shrink-0"
                         width="36" height="36" style="object-fit:cover" alt="">
                    <div class="flex-grow-1 min-w-0">
                        <div class="fw-semibold text-truncate">{{ user.nickname }}</div>
                        <small class="text-muted text-truncate d-block">{{ user.email }}</small>
                    </div>
                    <select name="role" class="form-select form-select-sm flex-shrink-0" style="width:auto">
                        <option value="editor">Editor</option>
                        <option value="viewer">Viewer</option>
                    </select>
                    <button type="submit" class="btn btn-sm btn-primary flex-shrink-0">Invitar</button>
                </form>
            </li>
        {% endfor %}
    </ul>
{% endif %}

{# Parámetros esperados: filterRoute, currentAccount, year, month, currentType, currentCategory, categories #}

<form method="get" action="{{ path(filterRoute) }}" class="row g-2 mb-3">
    <input type="hidden" name="account" value="{{ currentAccount.id }}">

    <div class="col-6 col-md-auto">
        <select name="month" class="form-select form-select-sm" onchange="this.form.submit()">
            {% for m in 1..12 %}
                <option value="{{ m }}" {{ m == month ? 'selected' : '' }}>
                    {{ (year ~ '-' ~ m|format_number({fraction_digit: 0}) ~ '-01')|date('F') }}
                </option>
            {% endfor %}
        </select>
    </div>

    <div class="col-6 col-md-auto">
        <select name="year" class="form-select form-select-sm" onchange="this.form.submit()">
            {% for y in (year - 2)..(year + 1) %}
                <option value="{{ y }}" {{ y == year ? 'selected' : '' }}>{{ y }}</option>
            {% endfor %}
        </select>
    </div>

    <div class="col-6 col-md-auto">
        <select name="type" class="form-select form-select-sm" onchange="this.form.submit()">
            <option value="">Todos los tipos</option>
            <option value="expense" {{ currentType == 'expense' ? 'selected' : '' }}>Gastos</option>
            <option value="income"  {{ currentType == 'income'  ? 'selected' : '' }}>Ingresos</option>
        </select>
    </div>

    <div class="col-6 col-md-auto">
        <select name="category" class="form-select form-select-sm" onchange="this.form.submit()">
            <option value="">Todas las categorías</option>
            {% for cat in categories %}
                <option value="{{ cat.id }}" {{ currentCategory == cat.id ? 'selected' : '' }}>{{ cat.name }}</option>
            {% endfor %}
        </select>
    </div>
</form>

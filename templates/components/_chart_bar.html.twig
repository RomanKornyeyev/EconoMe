<div class="card border-0 shadow-sm">
    <div class="card-body">
        <h6 class="card-title mb-3">Ingresos vs gastos</h6>
        <canvas id="barChart"></canvas>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const ctx = document.getElementById('barChart').getContext('2d');
    const months = ['Ene','Feb','Mar','Abr','May','Jun','Jul','Ago','Sep','Oct','Nov','Dic'];

    const incomeData  = new Array(12).fill(0);
    const expenseData = new Array(12).fill(0);
    {% for row in yearlyTotals %}
        incomeData[parseInt('{{ row.month }}') - 1]  = {{ row.totalIncome ?? 0 }};
        expenseData[parseInt('{{ row.month }}') - 1] = {{ row.totalExpense ?? 0 }};
    {% endfor %}

    new Chart(ctx, {
        type: 'bar',
        data: {
            labels: months,
            datasets: [
                {
                    label: 'Ingresos',
                    data: incomeData,
                    backgroundColor: 'rgba(75, 192, 130, 0.8)',
                    borderRadius: 4,
                    barPercentage: 0.6
                },
                {
                    label: 'Gastos',
                    data: expenseData,
                    backgroundColor: 'rgba(240, 149, 149, 0.8)',
                    borderRadius: 4,
                    barPercentage: 0.6
                }
            ]
        },
        options: {
            responsive: true,
            maintainAspectRatio: true,
            aspectRatio: 2.2,
            plugins: {
                legend: { position: 'bottom', labels: { boxWidth: 10, padding: 16, font: { size: 12 } } }
            },
            scales: {
                x: { grid: { display: false } },
                y: {
                    grid: { color: 'rgba(0,0,0,0.05)' },
                    ticks: { callback: v => v >= 1000 ? (v/1000) + 'k' : v },
                    border: { display: false }
                }
            }
        }
    });
});
</script>

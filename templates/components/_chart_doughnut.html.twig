{% set queryParams = app.request.query.all|merge({'categoryType': 'expense'}) %}
{% set urlExpense = '?' ~ queryParams|url_encode %}
{% set queryParams = app.request.query.all|merge({'categoryType': 'income'}) %}
{% set urlIncome  = '?' ~ queryParams|url_encode %}

<div class="card border shadow-sm bg-body-tertiary h-100">
    <div class="card-header border-bottom d-flex justify-content-between align-items-center" style="min-height: 3rem;">
        <h6 class="mb-0">Por categoría</h6>
        <div class="btn-group btn-group-sm" role="group">
            <a href="{{ urlExpense }}" class="btn {{ categoryType == 'expense' ? 'btn-secondary' : 'btn-outline-secondary' }}">Gastos</a>
            <a href="{{ urlIncome }}"  class="btn {{ categoryType == 'income'  ? 'btn-secondary' : 'btn-outline-secondary' }}">Ingresos</a>
        </div>
    </div>
    <div class="card-body">
        {% if expensesByCategory is empty %}
            <div class="d-flex flex-column justify-content-center align-items-center text-center h-100 gap-3 py-4">
                <p class="text-muted small mb-0">No hay {{ categoryType == 'income' ? 'ingresos' : 'gastos' }} este período.</p>
                <div class="d-flex flex-column gap-2">
                    <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#newTransactionModal">
                        <i class="fa-solid fa-plus me-1"></i>Añadir movimiento
                    </button>
                    <a href="{{ path('recurring_create', {account: currentAccount.id}) }}" class="btn btn-outline-primary btn-sm">
                        <i class="fa-solid fa-rotate me-1"></i>Añadir movimiento recurrente
                    </a>
                </div>
            </div>
        {% else %}
            <canvas id="doughnutChart"></canvas>
        {% endif %}
    </div>
</div>

{% if expensesByCategory is not empty %}
<script>
document.addEventListener('DOMContentLoaded', function() {
    const ctx = document.getElementById('doughnutChart').getContext('2d');

    new Chart(ctx, {
        type: 'doughnut',
        data: {
            labels: [{% for row in expensesByCategory %}'{{ row.categoryName ?? "Sin categoría" }}',{% endfor %}],
            datasets: [{
                data: [{% for row in expensesByCategory %}{{ row.total }},{% endfor %}],
                backgroundColor: [{% for row in expensesByCategory %}'{{ row.categoryColor ?? "#607D8B" }}',{% endfor %}],
                borderWidth: 0
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: true,
            aspectRatio: 1.2,
            cutout: '65%',
            plugins: {
                legend: { position: 'bottom', labels: { boxWidth: 8, padding: 10, font: { size: 11 } } }
            }
        }
    });
});
</script>
{% endif %}

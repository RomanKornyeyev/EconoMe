{% extends 'base.html.twig' %}

{% block title %}Movimientos{% endblock %}

{% block content %}
<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <h4 class="mb-0"><i class="fa-solid fa-arrow-right-arrow-left me-2"></i>Movimientos</h4>
    <a href="{{ path('transaction_create', {account: currentAccount.id}) }}" class="btn btn-primary btn-sm">
        <i class="fa-solid fa-plus me-1"></i>Nuevo movimiento
    </a>
</div>

{# Account selector #}
{% if accounts|length > 1 %}
    <div class="mb-3">
        <select class="form-select form-select-sm w-auto" onchange="window.location.href='?account='+this.value">
            {% for acc in accounts %}
                <option value="{{ acc.id }}" {{ acc.id == currentAccount.id ? 'selected' : '' }}>{{ acc.name }}</option>
            {% endfor %}
        </select>
    </div>
{% endif %}

{# Filters #}
<div class="card border-0 shadow-sm mb-3">
    <div class="card-body py-2">
        <form method="get" class="d-flex flex-wrap gap-2 align-items-end">
            <input type="hidden" name="account" value="{{ currentAccount.id }}">
            <div>
                <label class="form-label small mb-1">Año</label>
                <select name="year" class="form-select form-select-sm">
                    {% for y in (year - 2)..(year + 1) %}
                        <option value="{{ y }}" {{ y == year ? 'selected' : '' }}>{{ y }}</option>
                    {% endfor %}
                </select>
            </div>
            <div>
                <label class="form-label small mb-1">Mes</label>
                <select name="month" class="form-select form-select-sm">
                    <option value="">Todos</option>
                    {% for m in 1..12 %}
                        <option value="{{ m }}" {{ m == month ? 'selected' : '' }}>
                            {{ ('2000-' ~ m ~ '-01')|date('F') }}
                        </option>
                    {% endfor %}
                </select>
            </div>
            <div>
                <label class="form-label small mb-1">Tipo</label>
                <select name="type" class="form-select form-select-sm">
                    <option value="">Todos</option>
                    <option value="expense" {{ currentType == 'expense' ? 'selected' : '' }}>Gastos</option>
                    <option value="income" {{ currentType == 'income' ? 'selected' : '' }}>Ingresos</option>
                </select>
            </div>
            <div>
                <label class="form-label small mb-1">Categoría</label>
                <select name="category" class="form-select form-select-sm">
                    <option value="">Todas</option>
                    {% for cat in categories %}
                        <option value="{{ cat.id }}" {{ cat.id == currentCategory ? 'selected' : '' }}>{{ cat.name }}</option>
                    {% endfor %}
                </select>
            </div>
            <button type="submit" class="btn btn-sm btn-outline-primary">Filtrar</button>
            <a href="{{ path('transaction_index', {account: currentAccount.id}) }}" class="btn btn-sm btn-outline-secondary">Limpiar</a>
        </form>
    </div>
</div>

{# Transactions table #}
<div class="card border-0 shadow-sm" data-controller="bulk-select">
    <div class="card-header bg-transparent d-flex align-items-center">
        {# Estado normal #}
        <div data-bulk-select-target="normalBar" class="d-flex justify-content-between align-items-center w-100">
            <span class="text-muted small">
                {{ pagination.getTotalItemCount() }}
                {{ pagination.getTotalItemCount() == 1 ? 'movimiento' : 'movimientos' }}
            </span>
            <button class="btn btn-sm" style="visibility:hidden" aria-hidden="true" tabindex="-1">&nbsp;</button>
        </div>
        {# Estado bulk #}
        {% include 'transaction/_table_bulk_bar.html.twig' %}
    </div>

    {# Tabla desktop: visible en md+ #}
    <div class="d-none d-md-block">
        {% include 'transaction/_table_desktop.html.twig' with {'transactions': pagination} %}
    </div>

    {# Cards mobile: visible en < md #}
    <div class="d-md-none">
        {% include 'transaction/_cards_mobile.html.twig' with {'transactions': pagination} %}
    </div>

</div>

{# Pagination #}
<div class="mt-3 d-flex justify-content-center">
    {{ knp_pagination_render(pagination) }}
</div>
{% endblock %}

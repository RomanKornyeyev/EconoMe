{% extends 'base.html.twig' %}

{% block title %}Movimientos{% endblock %}

{% block content %}
{% set q = app.request.query.all %}

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <div class="d-flex align-items-center gap-2">
        <h1 class="mb-0 h3">Movimientos</h1>
        <div class="btn-group" role="group">
            <button type="button" class="btn btn-sm btn-outline-primary dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
                {{ currentAccount.name }}
            </button>
            <ul class="dropdown-menu">
                {% for acc in accounts %}
                    <li><a class="dropdown-item {{ acc.id == currentAccount.id ? 'active' : '' }}" href="?{{ q|merge({'account': acc.id, 'page': 1})|url_encode }}">{{ acc.name }}</a></li>
                {% endfor %}
            </ul>
        </div>
    </div>
    <a href="{{ path('transaction_create', {account: currentAccount.id}) }}" class="btn btn-primary btn-sm">
        <i class="fa-solid fa-plus me-1"></i>Nuevo movimiento
    </a>
</div>

{# Filters #}
<div class="card border-0 shadow-sm mb-3 bg-body-tertiary">
    <div class="card-body px-3 py-3">
        <form method="get">
            <input type="hidden" name="account" value="{{ currentAccount.id }}">
            <input type="hidden" name="sortBy" value="{{ sortField }}">
            <input type="hidden" name="sortDir" value="{{ sortDir }}">

            {# Fila 1: dropdowns #}
            <div class="row mb-2">
                {# Desde #}
                <div class="col-md-3">
                    <label class="form-label text-muted small mb-1">Desde</label>
                    <input type="text" name="date_from" class="form-control form-control-sm flatpickr-filter"
                           value="{{ dateFrom ? dateFrom|date('Y-m-d') : '' }}" placeholder="dd/mm/aaaa" autocomplete="off">
                </div>

                {# Hasta #}
                <div class="col-md-3">
                    <label class="form-label text-muted small mb-1">Hasta</label>
                    <input type="text" name="date_to" class="form-control form-control-sm flatpickr-filter"
                           value="{{ dateTo ? dateTo|date('Y-m-d') : '' }}" placeholder="dd/mm/aaaa" autocomplete="off">
                </div>

                {# Tipo #}
                <div class="col-md-3">
                    <label class="form-label text-muted small mb-1">Tipo</label>
                    <input type="hidden" name="type" id="f-type" value="{{ currentType ?? '' }}">
                    <div class="btn-group d-flex" role="group">
                        <button type="button" class="btn btn-sm btn-outline-primary dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
                            <span id="label-type">{% if currentType == 'expense' %}Gastos{% elseif currentType == 'income' %}Ingresos{% else %}Todos los tipos{% endif %}</span>
                        </button>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item filter-opt {{ not currentType ? 'active' : '' }}"
                                   data-input="f-type" data-label="label-type" data-value="" data-filters-cats="1"
                                   href="#">Todos los tipos</a></li>
                            <li><a class="dropdown-item filter-opt {{ currentType == 'expense' ? 'active' : '' }}"
                                   data-input="f-type" data-label="label-type" data-value="expense" data-filters-cats="1"
                                   href="#">Gastos</a></li>
                            <li><a class="dropdown-item filter-opt {{ currentType == 'income' ? 'active' : '' }}"
                                   data-input="f-type" data-label="label-type" data-value="income" data-filters-cats="1"
                                   href="#">Ingresos</a></li>
                        </ul>
                    </div>
                </div>

                {# Categoría #}
                <div class="col-md-3">
                    <label class="form-label text-muted small mb-1">Categoría</label>
                    <input type="hidden" name="category" id="f-category" value="{{ currentCategory is not null ? currentCategory : '' }}">
                    <div class="btn-group d-flex" role="group">
                        <button type="button" class="btn btn-sm btn-outline-primary dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
                            <span id="label-category">
                                {%- if currentCategory == -1 -%}Sin categoría
                                {%- elseif currentCategory -%}
                                    {%- for cat in categories -%}{%- if cat.id == currentCategory -%}{{ cat.name }}{%- endif -%}{%- endfor -%}
                                {%- else -%}Todas las categorías
                                {%- endif -%}
                            </span>
                        </button>
                        <ul class="dropdown-menu" id="cat-dropdown">
                            <li><a class="dropdown-item filter-opt {{ not currentCategory ? 'active' : '' }}"
                                   data-input="f-category" data-label="label-category" data-value=""
                                   href="#">Todas las categorías</a></li>
                            <li><a class="dropdown-item filter-opt {{ currentCategory == -1 ? 'active' : '' }}"
                                   data-input="f-category" data-label="label-category" data-value="-1"
                                   href="#">Sin categoría</a></li>
                            {% if categories|length > 0 %}
                                <li><hr class="dropdown-divider"></li>
                                {% for cat in categories %}
                                    <li data-cat-type="{{ cat.type }}">
                                        <a class="dropdown-item filter-opt {{ cat.id == currentCategory ? 'active' : '' }}"
                                           data-input="f-category" data-label="label-category" data-value="{{ cat.id }}"
                                           href="#">{{ cat.name }}</a>
                                    </li>
                                {% endfor %}
                            {% endif %}
                        </ul>
                    </div>
                </div>
            </div>

            {# Fila 2: texto libre #}
            <div class="row mb-4">
                <div class="col-12 col-md-6">
                    <label class="form-label text-muted small mb-1">Nombre</label>
                    <input type="text" name="search" class="form-control form-control-sm"
                           placeholder="Buscar por nombre…" value="{{ currentSearch ?? '' }}">
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label text-muted small mb-1">Descripción</label>
                    <input type="text" name="desc" class="form-control form-control-sm"
                           placeholder="Buscar por descripción…" value="{{ currentDesc ?? '' }}">
                </div>
            </div>

            {# Fila 3: acciones #}
            <div class="d-flex justify-content-end gap-3">
                <a href="{{ path('transaction_index', {account: currentAccount.id}) }}" class="btn btn-sm btn-outline-secondary">
                    <i class="fa-solid fa-eraser"></i>Limpiar
                </a>
                <button type="submit" class="btn btn-sm btn-primary px-4">
                    <i class="fa-solid fa-magnifying-glass me-1"></i>Filtrar
                </button>
            </div>
        </form>
    </div>
</div>

<script>
(function () {
    document.querySelectorAll('.filter-opt').forEach(function (link) {
        link.addEventListener('click', function (e) {
            e.preventDefault();
            document.getElementById(this.dataset.input).value = this.dataset.value;
            document.getElementById(this.dataset.label).textContent = this.textContent.trim();
            this.closest('ul').querySelectorAll('.dropdown-item').forEach(i => i.classList.remove('active'));
            this.classList.add('active');
            if (this.dataset.filtersCats) filterCats(this.dataset.value);
        });
    });

    function filterCats(type) {
        document.querySelectorAll('#cat-dropdown [data-cat-type]').forEach(function (li) {
            li.hidden = !!(type && li.dataset.catType !== type);
        });
        // Si la categoría seleccionada quedó oculta, resetear a "Todas"
        const catInput = document.getElementById('f-category');
        if (catInput.value && catInput.value !== '-1') {
            const sel = document.querySelector('#cat-dropdown [data-cat-type] a[data-value="' + catInput.value + '"]');
            if (sel && sel.closest('[data-cat-type]').hidden) {
                catInput.value = '';
                document.getElementById('label-category').textContent = 'Todas las categorías';
                document.querySelectorAll('#cat-dropdown .dropdown-item').forEach(i => i.classList.remove('active'));
                document.querySelector('#cat-dropdown a[data-value=""]').classList.add('active');
            }
        }
    }

    filterCats(document.getElementById('f-type').value);

    // Flatpickr para los campos de fecha del filtro
    document.querySelectorAll('.flatpickr-filter').forEach(function (el) {
        flatpickr(el, {
            locale: 'es',
            dateFormat: 'Y-m-d',
            altInput: true,
            altFormat: 'd/m/Y',
            altInputClass: 'form-control form-control-sm',
            allowInput: true,
        });
    });
})();
</script>

{# Transactions table #}
<div class="card border-0 shadow-sm" data-controller="bulk-select">
    <div class="card-header bg-transparent d-flex align-items-center">
        {# Estado normal #}
        <div data-bulk-select-target="normalBar" class="d-flex justify-content-between align-items-center w-100">
            <span class="text-muted small">
                {{ pagination.getTotalItemCount() }}
                {{ pagination.getTotalItemCount() == 1 ? 'movimiento' : 'movimientos' }}
            </span>
            <button class="btn btn-sm" style="visibility:hidden" aria-hidden="true" tabindex="-1">&nbsp;</button>
        </div>
        {# Estado bulk #}
        {% include 'transaction/_table_bulk_bar.html.twig' %}
    </div>

    {# Tabla desktop: visible en md+ #}
    <div class="d-none d-md-block">
        {% include 'transaction/_table_desktop.html.twig' with {'transactions': pagination} %}
    </div>

    {# Cards mobile: visible en < md #}
    <div class="d-md-none">
        {% include 'transaction/_cards_mobile.html.twig' with {'transactions': pagination} %}
    </div>

</div>

{# Pagination #}
<div class="mt-3 d-flex justify-content-center">
    {{ knp_pagination_render(pagination) }}
</div>
{% endblock %}

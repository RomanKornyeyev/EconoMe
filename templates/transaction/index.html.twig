{% extends 'base.html.twig' %}

{% block title %}Movimientos{% endblock %}

{% block content %}
{% import 'partials/macros/_tour.html.twig' as tour %}
{% set canEdit = is_granted('ACCOUNT_EDIT', currentAccount) %}

<div {{ tour.attrs('transactions') }}>

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <div class="d-flex align-items-center gap-2">
        <h1 class="mb-0 h3">Movimientos</h1>
        {% include 'partials/_account_selector.html.twig' with {
            accounts: accounts,
            current: currentAccount,
            resetParams: {page: 1, category: ''},
            tourStep: 1,
            tourTitle: 'Selector de cuenta',
            tourText: 'Aquí ves los movimientos de la cuenta seleccionada. Cambia de cuenta cuando quieras.',
        } only %}
    </div>
    <div class="d-flex align-items-center gap-2">
        <a href="{{ path('recurring_index', {account: currentAccount.id}) }}" class="btn btn-outline-primary btn-sm"
           data-tour-step="4"
           data-tour-title="Movimientos recurrentes"
           data-tour-text="Automatiza los gastos e ingresos periódicos (nómina, alquiler, suscripciones…) para no tener que registrarlos a mano.">
            <i class="fa-solid fa-rotate me-1"></i>Movimientos recurrentes
        </a>
        {% if canEdit %}
        <a href="{{ path('transaction_create', {account: currentAccount.id}) }}" class="btn btn-primary btn-sm"
           data-tour-step="5"
           data-tour-title="Nuevo movimiento"
           data-tour-text="Registra aquí tus gastos e ingresos.">
            <i class="fa-solid fa-plus me-1"></i>Nuevo movimiento
        </a>
        {% endif %}
        {{ tour.help_button() }}
    </div>
</div>

{# Filters #}
<div class="card border shadow-sm mb-3 bg-body-tertiary"
     data-tour-step="2"
     data-tour-title="Filtros"
     data-tour-text="Encuentra cualquier movimiento filtrando por fechas, tipo, categoría, texto o importe.">
    <div class="card-body px-4 py-4">
        <form method="get">
            <input type="hidden" name="account" value="{{ currentAccount.id }}">
            <input type="hidden" name="sortBy" value="{{ sortField }}">
            <input type="hidden" name="sortDir" value="{{ sortDir }}">

            {# Fila 1: dropdowns #}
            <div class="row mb-2">
                <div class="col-12 col-md-9">
                    <label class="form-label small mb-1">Nombre o descripción</label>
                    <input type="text" name="search" class="form-control form-control-sm"
                           placeholder="Buscar por nombre o descripción…" value="{{ currentSearch ?? '' }}">
                </div>

                {# Rango de fechas: un solo campo visible; los hidden alimentan al backend #}
                <div class="col-md-3">
                    <label class="form-label small mb-1">Fechas</label>
                    <input type="text" id="f-daterange" class="form-control form-control-sm"
                           placeholder="Selecciona un rango…" autocomplete="off">
                    <input type="hidden" name="date_from" id="f-date-from" value="{{ dateFrom ? dateFrom|date('Y-m-d') : '' }}">
                    <input type="hidden" name="date_to" id="f-date-to" value="{{ dateTo ? dateTo|date('Y-m-d') : '' }}">
                </div>
            </div>

            {# Fila 2: texto libre + importe #}
            <div class="row mb-4">
                {# Importes #}
                <div class="col-12 col-md-3">
                    <label class="form-label small mb-1">Importe desde</label>
                    <input type="number" name="amount_from" class="form-control form-control-sm"
                           placeholder="-25,00" step="0.01" value="{{ currentAmountFrom ?? '' }}">
                </div>
                <div class="col-12 col-md-3">
                    <label class="form-label small mb-1">Importe hasta</label>
                    <input type="number" name="amount_to" class="form-control form-control-sm"
                           placeholder="100,00" step="0.01" value="{{ currentAmountTo ?? '' }}">
                </div>

                {# Categoría #}
                <div class="col-md-3">
                    <label class="form-label small mb-1">Categoría</label>
                    <select name="category" id="f-category" class="form-select form-select-sm">
                        <option value="" {{ not currentCategory ? 'selected' : '' }}>Todas las categorías</option>
                        <option value="-1" {{ currentCategory == -1 ? 'selected' : '' }}>Sin categoría</option>
                        {% for cat in categories %}
                            <option value="{{ cat.id }}" data-cat-type="{{ cat.type }}"
                                    {{ cat.id == currentCategory ? 'selected' : '' }}>{{ cat.name }}</option>
                        {% endfor %}
                    </select>
                </div>

                {# Tipo #}
                <div class="col-md-3">
                    <label class="form-label small mb-1">Tipo</label>
                    <select name="type" id="f-type" class="form-select form-select-sm">
                        <option value="" {{ not currentType ? 'selected' : '' }}>Todos los tipos</option>
                        <option value="expense" {{ currentType == 'expense' ? 'selected' : '' }}>Gastos</option>
                        <option value="income" {{ currentType == 'income' ? 'selected' : '' }}>Ingresos</option>
                    </select>
                </div>
            </div>

            {# Fila 3: acciones #}
            <div class="d-flex justify-content-end gap-3">
                <a href="{{ path('transaction_index', {account: currentAccount.id}) }}" class="btn btn-sm btn-outline-primary">
                    <i class="fa-solid fa-eraser"></i>Limpiar
                </a>
                <button type="submit" class="btn btn-sm btn-primary px-4">
                    <i class="fa-solid fa-magnifying-glass me-1"></i>Filtrar
                </button>
            </div>
        </form>
    </div>
</div>

<script>
(function () {
    function filterCats(type) {
        const catSelect = document.getElementById('f-category');
        catSelect.querySelectorAll('option[data-cat-type]').forEach(function (opt) {
            const matches = !type || opt.dataset.catType === type;
            opt.hidden = !matches;
            opt.disabled = !matches;
        });
        const selected = catSelect.options[catSelect.selectedIndex];
        if (selected && (selected.hidden || selected.disabled)) {
            catSelect.value = '';
        }
    }

    document.getElementById('f-type').addEventListener('change', function () {
        filterCats(this.value);
    });

    filterCats(document.getElementById('f-type').value);

    // Flatpickr en modo rango: un campo visible, dos hidden (date_from/date_to)
    const hiddenFrom = document.getElementById('f-date-from');
    const hiddenTo = document.getElementById('f-date-to');

    function syncHidden(dates, dateStr, fp) {
        hiddenFrom.value = dates[0] ? fp.formatDate(dates[0], 'Y-m-d') : '';
        // Con un solo día seleccionado, filtramos exactamente ese día
        hiddenTo.value = dates[1] ? fp.formatDate(dates[1], 'Y-m-d')
                       : (dates[0] ? fp.formatDate(dates[0], 'Y-m-d') : '');
    }

    // Si inicio y fin coinciden, muestra la fecha una sola vez (en vez de "X a X")
    function tidyDisplay(fp) {
        const d = fp.selectedDates;
        if (d.length === 2 && d[0].getTime() === d[1].getTime()) {
            fp.altInput.value = fp.formatDate(d[0], 'd/m/Y');
        }
    }

    flatpickr('#f-daterange', {
        mode: 'range',
        locale: 'es',
        dateFormat: 'Y-m-d',
        altInput: true,
        altFormat: 'd/m/Y',
        altInputClass: 'form-control form-control-sm',
        defaultDate: [
            {% if dateFrom %}'{{ dateFrom|date('Y-m-d') }}',{% endif %}
            {% if dateTo %}'{{ dateTo|date('Y-m-d') }}',{% endif %}
        ],
        onChange: syncHidden,
        onClose: function (dates, dateStr, fp) {
            // Rango a medias (1 sola fecha): consolidarlo como día único
            // también a nivel visual, no solo en los hidden
            if (dates.length === 1) {
                fp.setDate([dates[0], dates[0]], false);
            }
            syncHidden(fp.selectedDates, dateStr, fp);
            tidyDisplay(fp);
        },
        onReady: function (dates, dateStr, fp) {
            tidyDisplay(fp);
        },
    });
})();
</script>

{# Transactions table #}
<div class="card border shadow-sm" id="table_transactions" data-controller="bulk-select"
     data-tour-step="3"
     data-tour-title="Tus movimientos"
     data-tour-text="El listado completo de la cuenta. Ordena haciendo clic en las columnas y selecciona varios movimientos para acciones en bloque."
     data-tour-side="top">
    <div class="card-header bg-body-tertiary border-bottom d-flex align-items-center">
        {# Estado normal #}
        <div data-bulk-select-target="normalBar" class="d-flex justify-content-between align-items-center w-100">
            <span class="text-muted small">
                {{ pagination.getTotalItemCount() }}
                {{ pagination.getTotalItemCount() == 1 ? 'movimiento' : 'movimientos' }}
            </span>
            <button class="btn btn-sm" style="visibility:hidden" aria-hidden="true" tabindex="-1">&nbsp;</button>
        </div>
        {# Estado bulk #}
        {% include 'transaction/_table_bulk_bar.html.twig' %}
    </div>

    {# Tabla desktop: visible en md+ #}
    <div class="d-none d-md-block">
        {% include 'transaction/_table_desktop.html.twig' with {'transactions': pagination} %}
    </div>

    {# Cards mobile: visible en < md #}
    <div class="d-md-none">
        {% include 'transaction/_cards_mobile.html.twig' with {'transactions': pagination} %}
    </div>

</div>

{# Pagination #}
<div class="mt-3 d-flex justify-content-center">
    {{ knp_pagination_render(pagination) }}
</div>

{% include 'transaction/_modal_summary.html.twig' %}

</div> {# /tour #}
{% endblock %}

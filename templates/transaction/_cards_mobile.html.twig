<div class="p-3 d-flex flex-column gap-2">
    {% for tx in transactions %}
    <div class="bg-body-secondary rounded-3 p-3">
        <div class="d-flex justify-content-between align-items-center mb-1">
            <span class="fw-semibold small">
                {{ tx.name }}
                {% if tx.wasGeneratedAutomatically() %}
                    <span class="badge bg-body text-muted ms-1" style="font-size:10px">Auto</span>
                {% endif %}
            </span>
            <div class="d-flex align-items-center gap-2">
                <span class="fw-semibold {{ tx.isExpense() ? 'text-danger' : 'text-success' }}">
                    {{ tx.isExpense() ? '-' : '+' }}{{ tx.amount|number_format(2, ',', '.') }}
                </span>
                <div class="dropdown">
                    <button class="btn btn-sm btn-outline-secondary text-muted text-decoration-none lh-1" data-bs-toggle="dropdown" aria-expanded="false">&#8942;</button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li>
                            <a class="dropdown-item" href="{{ path('transaction_edit', {id: tx.id}) }}">
                                <i class="fa-solid fa-pen fa-sm me-2 text-muted"></i>Editar
                            </a>
                        </li>
                        <li>
                            <button class="dropdown-item text-danger"
                                    data-action="click->bulk-select#confirmSingleDelete"
                                    data-url="{{ path('transaction_delete', {id: tx.id}) }}"
                                    data-token="{{ csrf_token('delete' ~ tx.id) }}"
                                    data-name="{{ tx.name }}">
                                <i class="fa-solid fa-trash fa-sm me-2"></i>Eliminar
                            </button>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="d-flex justify-content-between align-items-center">
            <span class="text-muted" style="font-size:12px">{{ tx.date|date('d/m/Y') }}</span>
            {% if tx.category %}
                <span style="font-size:12px" class="text-muted">
                    <span class="d-inline-block rounded-circle me-1" style="width:6px;height:6px;background:{{ tx.category.color }}"></span>
                    {{ tx.category.name }}
                </span>
            {% endif %}
        </div>
    </div>
    {% else %}
        <p class="text-center text-muted py-4 mb-0">No hay movimientos.</p>
    {% endfor %}
</div>

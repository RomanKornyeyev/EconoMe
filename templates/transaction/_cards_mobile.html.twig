<div class="p-3 d-flex flex-column gap-2">
    {% for tx in transactions %}
    <div class="bg-body-secondary rounded-3 p-3">
        <div class="d-flex justify-content-between align-items-center mb-1">
            <span class="fw-semibold small">{{ tx.name }}</span>
            <span class="fw-semibold {{ tx.isExpense() ? 'text-danger' : 'text-success' }}">
                {{ tx.isExpense() ? '-' : '+' }}{{ tx.amount|number_format(2, ',', '.') }}
            </span>
        </div>
        <div class="d-flex justify-content-between align-items-center">
            <span class="text-muted" style="font-size:12px">{{ tx.date|date('d/m/Y') }}</span>
            {% if tx.category %}
                <span style="font-size:12px" class="text-muted">
                    <span class="d-inline-block rounded-circle me-1" style="width:6px;height:6px;background:{{ tx.category.color }}"></span>
                    {{ tx.category.name }}
                </span>
            {% endif %}
        </div>
    </div>
    {% else %}
        <p class="text-center text-muted py-4 mb-0">No hay movimientos.</p>
    {% endfor %}
</div>

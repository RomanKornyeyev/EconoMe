{% set q = app.request.query.all %}
{% set sf = sortField ?? app.request.query.get('sortBy', 'date') %}
{% set sd = sortDir ?? app.request.query.get('sortDir', 'desc') %}
{% macro sortHeader(q, field, label, sf, sd, extraClass) %}
	{% set active = (sf == field) %}
	{% set newDir = (active and sd == 'asc') ? 'desc' : 'asc' %}
	{% set icon = active ? (sd == 'asc' ? '<i class="fa-solid fa-sort-up fa-xs ms-1"></i>' : '<i class="fa-solid fa-sort-down fa-xs ms-1"></i>') : '<i class="fa-solid fa-sort fa-xs ms-1 opacity-25"></i>' %}
	<th class="text-muted small text-uppercase fw-normal {{ extraClass }}">
		<a href="?{{ q|merge({'sortBy': field, 'sortDir': newDir, 'page': 1})|url_encode }}" class="text-reset text-decoration-none text-nowrap">{{ label }}{{ icon|raw }}</a>
	</th>
{% endmacro %}

{# Form bulk delete: fuera de la tabla para evitar anidamiento. Checkboxes se asocian via form="bulkForm". #}
<form id="bulkForm" data-bulk-select-target="bulkForm"
      method="post" action="{{ path('transaction_bulk_delete') }}">
	<input type="hidden" name="_token" value="{{ csrf_token('bulk_delete') }}">
	<input type="hidden" name="_redirect_url" value="{{ app.request.requestUri }}">
</form>

{# Form single delete: action y token se inyectan dinámicamente desde el controller. #}
<form data-bulk-select-target="singleDeleteForm" method="post">
	<input type="hidden" name="_token" data-bulk-select-target="singleDeleteToken">
	<input type="hidden" name="_redirect_url" value="{{ app.request.requestUri }}">
</form>

<table class="table table-hover align-middle mb-0">
	<thead style="--bs-table-bg: var(--bs-tertiary-bg);">
		<tr>
			<th style="width:2.5rem">
				<input type="checkbox"
				       class="form-check-input"
				       title="Seleccionar todo"
				       data-bulk-select-target="selectAll"
				       data-action="change->bulk-select#toggleAll">
			</th>
			{{ _self.sortHeader(q, 'date',     'Fecha',     sf, sd, '') }}
			{{ _self.sortHeader(q, 'name',     'Nombre',    sf, sd, '') }}
			<th class="text-muted small text-uppercase fw-normal">Descripción</th>
			{{ _self.sortHeader(q, 'category', 'Categoría', sf, sd, '') }}
			{{ _self.sortHeader(q, 'type',     'Tipo',      sf, sd, '') }}
			{{ _self.sortHeader(q, 'amount',   'Importe',   sf, sd, 'text-end') }}
			<th class="text-muted small text-uppercase fw-normal text-end">Acciones</th>
		</tr>
	</thead>
	<tbody>
		{% for tx in transactions %}
			<tr>
				<td>
					<input type="checkbox" name="ids[]" value="{{ tx.id }}"
					       class="form-check-input"
					       form="bulkForm"
					       data-bulk-select-target="checkbox"
					       data-action="change->bulk-select#toggle">
				</td>
				<td class="small">{{ tx.date|date('d/m/Y') }}</td>
				<td class="fw-semibold">
					{% if tx.name|length > 20 %}
						<span data-bs-toggle="tooltip" data-bs-title="{{ tx.name }}">{{ tx.name|slice(0,20) }}…</span>
					{% else %}
						{{ tx.name }}
					{% endif %}
					{% if tx.wasGeneratedAutomatically() %}
						<span class="badge bg-body-secondary text-muted ms-1" style="font-size:10px">Auto</span>
					{% endif %}
				</td>
				<td class="text-muted">
					{% if tx.description %}
						{% if tx.description|length > 20 %}
							<span data-bs-toggle="tooltip" data-bs-title="{{ tx.description }}">{{ tx.description|slice(0,20) }}…</span>
						{% else %}
							{{ tx.description }}
						{% endif %}
					{% else %}—{% endif %}
				</td>
				<td>
					{% if tx.category %}
						<span class="d-inline-block rounded-circle me-1" style="width:8px;height:8px;background:{{ tx.category.color }}"></span>
						<span class="small">{{ tx.category.name }}</span>
					{% else %}
						<span class="small text-muted">—</span>
					{% endif %}
				</td>
				<td>
					{% if tx.isExpense() %}
						<span class="badge bg-danger-subtle text-danger">Gasto</span>
					{% else %}
						<span class="badge bg-success-subtle text-success">Ingreso</span>
					{% endif %}
				</td>
				<td class="text-end fw-semibold {{ tx.isExpense() ? 'text-danger' : 'text-success' }}">
					{{ tx.isExpense() ? '-' : '+' }}{{ tx.amount|number_format(2, ',', '.') }}
				</td>
				<td class="text-end">
					<div class="d-inline-flex gap-2">
						<button type="button"
						        class="btn btn-sm btn-outline-primary py-0 px-1"
						        data-bs-toggle="tooltip" data-bs-title="Ver detalle" aria-label="Ver detalle"
						        data-controller="tx-summary"
						        data-tx-summary-url-value="{{ path('transaction_summary', {id: tx.id}) }}"
						        data-action="click->tx-summary#show">
							<i class="fa-solid fa-eye fa-sm"></i>
						</button>
						<a href="{{ path('transaction_edit', {id: tx.id}) }}"
						   class="btn btn-sm btn-outline-primary py-0 px-1"
						   data-bs-toggle="tooltip" data-bs-title="Editar" aria-label="Editar">
							<i class="fa-solid fa-pen fa-sm"></i>
						</a>
						<button type="button"
						        class="btn btn-sm btn-outline-danger py-0 px-1"
						        data-bs-toggle="tooltip" data-bs-title="Eliminar" aria-label="Eliminar"
						        data-action="click->bulk-select#confirmSingleDelete"
						        data-url="{{ path('transaction_delete', {id: tx.id}) }}"
						        data-token="{{ csrf_token('delete' ~ tx.id) }}"
						        data-name="{{ tx.name }}">
							<i class="fa-solid fa-trash fa-sm"></i>
						</button>
					</div>
				</td>
			</tr>
		{% else %}
			<tr>
				<td colspan="8" class="text-center text-muted py-4">No hay movimientos para este periodo.</td>
			</tr>
		{% endfor %}
	</tbody>
</table>

{# Modal de confirmación — bulk delete #}
<div class="modal fade" id="bulkConfirmModal" tabindex="-1" aria-labelledby="bulkConfirmModalLabel" aria-hidden="true">
	<div class="modal-dialog modal-dialog-centered">
		<div class="modal-content">
			<div class="modal-header border-0 pb-0">
				<h5 class="modal-title" id="bulkConfirmModalLabel">Eliminar movimientos</h5>
				<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
			</div>
			<div class="modal-body">
				¿Eliminar <strong data-bulk-select-target="confirmCount"></strong>? Esta acción no se puede deshacer.
			</div>
			<div class="modal-footer border-0 pt-0">
				<button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
				<button type="button" class="btn btn-danger" data-action="bulk-select#submitBulk">
					<i class="fa-solid fa-trash fa-xs me-1"></i>Eliminar
				</button>
			</div>
		</div>
	</div>
</div>

{# Modal de confirmación — borrado individual #}
<div class="modal fade" id="singleConfirmModal"
     data-bulk-select-target="singleDeleteModal"
     tabindex="-1" aria-labelledby="singleConfirmModalLabel" aria-hidden="true">
	<div class="modal-dialog modal-dialog-centered">
		<div class="modal-content">
			<div class="modal-header border-0 pb-0">
				<h5 class="modal-title" id="singleConfirmModalLabel">Eliminar movimiento</h5>
				<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
			</div>
			<div class="modal-body">
				¿Eliminar <strong data-bulk-select-target="singleDeleteName"></strong>? Esta acción no se puede deshacer.
			</div>
			<div class="modal-footer border-0 pt-0">
				<button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
				<button type="button" class="btn btn-danger" data-action="bulk-select#submitSingleDelete">
					<i class="fa-solid fa-trash fa-xs me-1"></i>Eliminar
				</button>
			</div>
		</div>
	</div>
</div>

{% set q = app.request.query.all %}
{% set sf = sortField ?? app.request.query.get('sortBy', 'date') %}
{% set sd = sortDir ?? app.request.query.get('sortDir', 'desc') %}
{% macro sortHeader(q, field, label, sf, sd, extraClass) %}
	{% set active = (sf == field) %}
	{% set newDir = (active and sd == 'asc') ? 'desc' : 'asc' %}
	{% set icon = active ? (sd == 'asc' ? '<i class="fa-solid fa-sort-up fa-xs ms-1"></i>' : '<i class="fa-solid fa-sort-down fa-xs ms-1"></i>') : '<i class="fa-solid fa-sort fa-xs ms-1 opacity-25"></i>' %}
	<th class="text-muted small text-uppercase fw-normal {{ extraClass }}">
		<a href="?{{ q|merge({'sortBy': field, 'sortDir': newDir, 'page': 1})|url_encode }}" class="text-reset text-decoration-none text-nowrap">{{ label }}{{ icon|raw }}</a>
	</th>
{% endmacro %}

{# Form bulk: fuera de la tabla para evitar anidamiento. Los checkboxes se asocian via form="bulkForm". #}
<form id="bulkForm" method="post" action="{{ path('transaction_bulk_delete') }}">
	<input type="hidden" name="_token" value="{{ csrf_token('bulk_delete') }}">
	<input type="hidden" name="_redirect_url" value="{{ app.request.requestUri }}">
</form>

<table class="table table-hover align-middle mb-0">
	<thead>
		<tr>
			<th style="width:2.5rem">
				<input type="checkbox" id="selectAll" class="form-check-input" title="Seleccionar todo">
			</th>
			{{ _self.sortHeader(q, 'date',     'Fecha',     sf, sd, '') }}
			{{ _self.sortHeader(q, 'name',     'Nombre',    sf, sd, '') }}
			<th class="text-muted small text-uppercase fw-normal">Descripción</th>
			{{ _self.sortHeader(q, 'category', 'Categoría', sf, sd, '') }}
			{{ _self.sortHeader(q, 'type',     'Tipo',      sf, sd, '') }}
			{{ _self.sortHeader(q, 'amount',   'Importe',   sf, sd, 'text-end') }}
			<th></th>
		</tr>
	</thead>
	<tbody>
		{% for tx in transactions %}
			<tr>
				<td>
					{# form="bulkForm" asocia el checkbox al form externo sin anidamiento #}
					<input type="checkbox" name="ids[]" value="{{ tx.id }}" class="form-check-input tx-check" form="bulkForm">
				</td>
				<td class="small">{{ tx.date|date('d/m/Y') }}</td>
				<td class="fw-semibold">
					{{ tx.name }}
					{% if tx.wasGeneratedAutomatically() %}
						<span class="badge bg-body-secondary text-muted ms-1" style="font-size:10px">Auto</span>
					{% endif %}
				</td>
				<td class="text-muted">
					{% if tx.description %}
						{{ tx.description|slice(0,8) }}
						{% if tx.description|length > 8 %}…
						{% endif %}
					{% else %}—
					{% endif %}
				</td>
				<td>
					{% if tx.category %}
						<span class="d-inline-block rounded-circle me-1" style="width:8px;height:8px;background:{{ tx.category.color }}"></span>
						<span class="small">{{ tx.category.name }}</span>
					{% else %}
						<span class="small text-muted">—</span>
					{% endif %}
				</td>
				<td>
					{% if tx.isExpense() %}
						<span class="badge bg-danger-subtle text-danger">Gasto</span>
					{% else %}
						<span class="badge bg-success-subtle text-success">Ingreso</span>
					{% endif %}
				</td>
				<td class="text-end fw-semibold {{ tx.isExpense() ? 'text-danger' : 'text-success' }}">
					{{ tx.isExpense() ? '-' : '+' }}{{ tx.amount|number_format(2, ',', '.') }}
				</td>
				<td>
					<div class="dropdown">
						<button class="btn btn-sm btn-link text-muted text-decoration-none p-0" data-bs-toggle="dropdown">
							&#8942;
						</button>
						<ul class="dropdown-menu dropdown-menu-end">
							<li>
								<a class="dropdown-item" href="{{ path('transaction_edit', {id: tx.id}) }}">Editar</a>
							</li>
							<li>
								<form method="post" action="{{ path('transaction_delete', {id: tx.id}) }}" onsubmit="return confirm('¿Eliminar este movimiento?')">
									<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ tx.id) }}">
									<button class="dropdown-item text-danger">Eliminar</button>
								</form>
							</li>
						</ul>
					</div>
				</td>
			</tr>
		{% else %}
			<tr>
				<td colspan="8" class="text-center text-muted py-4">No hay movimientos para este periodo.</td>
			</tr>
		{% endfor %}
	</tbody>
</table>

{# Modal de confirmación bulk delete #}
<div class="modal fade" id="bulkConfirmModal" tabindex="-1" aria-labelledby="bulkConfirmModalLabel" aria-hidden="true">
	<div class="modal-dialog modal-dialog-centered">
		<div class="modal-content">
			<div class="modal-header border-0 pb-0">
				<h5 class="modal-title" id="bulkConfirmModalLabel">Eliminar movimientos</h5>
				<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
			</div>
			<div class="modal-body">
				¿Eliminar <strong id="bulkConfirmCount"></strong>? Esta acción no se puede deshacer.
			</div>
			<div class="modal-footer border-0 pt-0">
				<button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
				<button type="button" class="btn btn-danger" id="bulkConfirmOk">
					<i class="fa-solid fa-trash fa-xs me-1"></i>Eliminar
				</button>
			</div>
		</div>
	</div>
</div>

<script>
(function () {
	const selectAll        = document.getElementById('selectAll');
	const cardPeriodLabel  = document.getElementById('cardPeriodLabel');
	const cardBulkActions  = document.getElementById('cardBulkActions');
	const cardVerTodos     = document.getElementById('cardVerTodos');
	const bulkClear        = document.getElementById('bulkClear');
	const bulkConfirmCount = document.getElementById('bulkConfirmCount');
	const bulkConfirmOk    = document.getElementById('bulkConfirmOk');
	const periodText       = cardPeriodLabel.textContent;

	function getChecked() { return document.querySelectorAll('.tx-check:checked'); }
	function getAll()     { return document.querySelectorAll('.tx-check'); }
	function label(n)     { return n === 1 ? '1 movimiento' : n + ' movimientos'; }

	function update() {
		const n      = getChecked().length;
		const total  = getAll().length;
		const active = n > 0;

		cardBulkActions.classList.toggle('d-none', !active);
		cardBulkActions.classList.toggle('d-flex', active);
		cardVerTodos.classList.toggle('d-none', active);
		cardPeriodLabel.textContent = active ? (n === 1 ? '· 1 seleccionado' : '· ' + n + ' seleccionados') : periodText;

		selectAll.checked       = active && n === total;
		selectAll.indeterminate = active && n < total;
	}

	selectAll.addEventListener('change', function () {
		getAll().forEach(cb => cb.checked = this.checked);
		update();
	});

	document.querySelectorAll('.tx-check').forEach(cb => cb.addEventListener('change', update));

	bulkClear.addEventListener('click', function () {
		getAll().forEach(cb => cb.checked = false);
		selectAll.checked       = false;
		selectAll.indeterminate = false;
		update();
	});

	document.getElementById('bulkConfirmModal').addEventListener('show.bs.modal', function () {
		bulkConfirmCount.textContent = label(getChecked().length);
	});

	bulkConfirmOk.addEventListener('click', function () {
		document.getElementById('bulkForm').submit();
	});
})();
</script>

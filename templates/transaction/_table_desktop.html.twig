{% set q = app.request.query.all %}
{% set sf = sortField ?? app.request.query.get('sortBy', 'date') %}
{% set sd = sortDir ?? app.request.query.get('sortDir', 'desc') %}
{% macro sortHeader(q, field, label, sf, sd, extraClass) %}
	{% set active = (sf == field) %}
	{% set newDir = (active and sd == 'asc') ? 'desc' : 'asc' %}
	{% set icon = active ? (sd == 'asc' ? '<i class="fa-solid fa-sort-up fa-xs ms-1"></i>' : '<i class="fa-solid fa-sort-down fa-xs ms-1"></i>') : '<i class="fa-solid fa-sort fa-xs ms-1 opacity-25"></i>' %}
	<th class="text-muted small text-uppercase fw-normal {{ extraClass }}">
		<a href="?{{ q|merge({'sortBy': field, 'sortDir': newDir, 'page': 1})|url_encode }}" class="text-reset text-decoration-none text-nowrap">{{ label }}{{ icon|raw }}</a>
	</th>
{% endmacro %}

<table class="table table-hover align-middle mb-0">
	<thead>
		<tr>
			{{ _self.sortHeader(q, 'date',     'Fecha',     sf, sd, '') }}
			{{ _self.sortHeader(q, 'name',     'Nombre',    sf, sd, '') }}
			<th class="text-muted small text-uppercase fw-normal">Descripción</th>
			{{ _self.sortHeader(q, 'category', 'Categoría', sf, sd, '') }}
			{{ _self.sortHeader(q, 'type',     'Tipo',      sf, sd, '') }}
			{{ _self.sortHeader(q, 'amount',   'Importe',   sf, sd, 'text-end') }}
			<th></th>
		</tr>
	</thead>
	<tbody>
		{% for tx in transactions %}
			<tr>
				<td class="small">{{ tx.date|date('d/m/Y') }}</td>
				<td class="fw-semibold">
					{{ tx.name }}
					{% if tx.wasGeneratedAutomatically() %}
						<span class="badge bg-body-secondary text-muted ms-1" style="font-size:10px">Auto</span>
					{% endif %}
				</td>
				<td class="text-muted">
					{% if tx.description %}
						{{ tx.description|slice(0,8) }}
						{% if tx.description|length > 8 %}…
						{% endif %}
						{% else %}—
					{% endif %}
				</td>
				<td>
					{% if tx.category %}
						<span class="d-inline-block rounded-circle me-1" style="width:8px;height:8px;background:{{ tx.category.color }}"></span>
						<span class="small">{{ tx.category.name }}</span>
					{% else %}
						<span class="small text-muted">—</span>
					{% endif %}
				</td>
				<td>
					{% if tx.isExpense() %}
						<span class="badge bg-danger-subtle text-danger">Gasto</span>
					{% else %}
						<span class="badge bg-success-subtle text-success">Ingreso</span>
					{% endif %}
				</td>
				<td class="text-end fw-semibold {{ tx.isExpense() ? 'text-danger' : 'text-success' }}">
					{{ tx.isExpense() ? '-' : '+' }}{{ tx.amount|number_format(2, ',', '.') }}
				</td>
				<td>
					<div class="dropdown">
						<button class="btn btn-sm btn-link text-muted text-decoration-none p-0" data-bs-toggle="dropdown">
							&#8942;
						</button>
						<ul class="dropdown-menu dropdown-menu-end">
							<li>
								<a class="dropdown-item" href="{{ path('transaction_edit', {id: tx.id}) }}">Editar</a>
							</li>
							<li>
								<form method="post" action="{{ path('transaction_delete', {id: tx.id}) }}" onsubmit="return confirm('¿Eliminar este movimiento?')">
									<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ tx.id) }}">
									<button class="dropdown-item text-danger">Eliminar</button>
								</form>
							</li>
						</ul>
					</div>
				</td>
			</tr>
		{% else %}
			<tr>
				<td colspan="7" class="text-center text-muted py-4">No hay movimientos para este periodo.</td>
			</tr>
		{% endfor %}
	</tbody>
</table>

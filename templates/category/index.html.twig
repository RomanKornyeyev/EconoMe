{% extends 'base.html.twig' %}

{% block title %}Categorías{% endblock %}

{% block content %}
{% import 'partials/macros/_tour.html.twig' as tour %}

<div {{ tour.attrs('categories', not isTemplateView) }}>

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <div class="d-flex align-items-center gap-2">
        <h4 class="mb-0">Categorías</h4>

        <div class="btn-group" role="group"
             data-tour-step="1"
             data-tour-title="Cuenta o plantilla"
             data-tour-text="Cada cuenta tiene sus propias categorías. Además, dispones de «Mi plantilla»: un juego personal de categorías que puedes aplicar al crear cuentas nuevas.">
            <button type="button" class="btn btn-sm btn-outline-primary dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
                {% if isTemplateView %}
                    Mi plantilla
                {% else %}
                    {{ currentAccount.name }}
                {% endif %}
            </button>
            <ul class="dropdown-menu">
                {% for acc in accounts %}
                    <li>
                        <a class="dropdown-item {{ not isTemplateView and acc.id == currentAccount.id ? 'active' : '' }}"
                           href="{{ path('category_index', {account: acc.id}) }}">
                            {{ acc.name }}
                        </a>
                    </li>
                {% endfor %}
                {% if accounts is not empty %}
                    <li><hr class="dropdown-divider"></li>
                {% endif %}
                <li>
                    <a class="dropdown-item {{ isTemplateView ? 'active' : '' }}"
                       href="{{ path('category_index', {template: 'true'}) }}">
                        Mi plantilla
                    </a>
                </li>
            </ul>
        </div>
    </div>

    <div class="d-flex align-items-center gap-2">
        {% if isTemplateView %}
            <a href="{{ path('category_template_create') }}" class="btn btn-primary btn-sm">
                <i class="fa-solid fa-plus me-1"></i>Nueva categoría (plantilla)
            </a>
        {% elseif is_granted('ACCOUNT_EDIT', currentAccount) %}
            <a href="{{ path('category_create', {account: currentAccount.id}) }}" class="btn btn-primary btn-sm"
               data-tour-step="2"
               data-tour-title="Crea categorías"
               data-tour-text="Añade las categorías que necesites para clasificar tus gastos e ingresos.">
                <i class="fa-solid fa-plus me-1"></i>Nueva categoría
            </a>
        {% endif %}
        {{ tour.help_button() }}
    </div>
</div>

{# ── Vista: plantillas ───────────────────────────────────────────────────── #}
{% if isTemplateView %}

    <div class="alert alert-primary d-flex align-items-center gap-2 py-2 mb-3" role="alert">
        <i class="fa-solid fa-circle-info"></i>
        <span>Esta es tu plantilla de categorías. Podrás usarlas para tus nuevas cuentas.</span>
    </div>

    {% set tplExpenses = templates|filter(t => t.type == 'expense') %}
    {% set tplIncomes  = templates|filter(t => t.type == 'income') %}

    {% if templates is empty %}
        <div class="text-center py-5">
            <i class="fa-solid fa-layer-group fa-3x text-muted mb-3"></i>
            <h5 class="text-muted">Tu plantilla de categorías está vacía</h5>
            <a href="{{ path('category_template_create') }}" class="btn btn-primary mt-2">
                <i class="fa-solid fa-plus me-1"></i>Crear categoría (plantilla)
            </a>
        </div>
    {% else %}
        <div class="row g-3">
            {% if tplExpenses is not empty %}
                <div class="col-12 col-md-6">
                    <div class="card shadow border">
                        <div class="card-header bg-body-tertiary border-bottom">
                            <h6 class="mb-0 text-danger"><i class="fa-solid fa-arrow-trend-down me-2"></i>Gastos</h6>
                        </div>
                        <ul class="list-group list-group-flush">
                            {% for tpl in tplExpenses %}
                                <li class="list-group-item d-flex align-items-center justify-content-between">
                                    <div class="d-flex align-items-center gap-2">
                                        {% if tpl.color %}
                                            <span class="rounded-circle d-inline-block" style="width:12px;height:12px;background:{{ tpl.color }}"></span>
                                        {% endif %}
                                        <span>{{ tpl.name }}</span>
                                    </div>
                                    <div class="d-flex align-items-center gap-2">
                                        <a href="{{ path('category_template_edit', {id: tpl.id}) }}" class="btn btn-sm btn-outline-primary py-0 px-1">
                                            <i class="fa-solid fa-pen"></i>
                                        </a>
                                        <form method="post" action="{{ path('category_template_delete', {id: tpl.id}) }}" class="d-flex"
                                              data-controller="confirm"
                                              data-action="submit->confirm#submit"
                                              data-confirm-message-value="¿Eliminar la plantilla «{{ tpl.name }}»?"
                                              data-confirm-text-value="Eliminar">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ tpl.id) }}">
                                            <button type="submit" class="btn btn-sm btn-outline-danger py-0 px-1">
                                                <i class="fa-solid fa-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </li>
                            {% endfor %}
                        </ul>
                    </div>
                </div>
            {% endif %}

            {% if tplIncomes is not empty %}
                <div class="col-12 col-md-6">
                    <div class="card shadow border">
                        <div class="card-header bg-body-tertiary border-bottom">
                            <h6 class="mb-0 text-success"><i class="fa-solid fa-arrow-trend-up me-2"></i>Ingresos</h6>
                        </div>
                        <ul class="list-group list-group-flush">
                            {% for tpl in tplIncomes %}
                                <li class="list-group-item d-flex align-items-center justify-content-between">
                                    <div class="d-flex align-items-center gap-2">
                                        {% if tpl.color %}
                                            <span class="rounded-circle d-inline-block" style="width:12px;height:12px;background:{{ tpl.color }}"></span>
                                        {% endif %}
                                        <span>{{ tpl.name }}</span>
                                    </div>
                                    <div class="d-flex align-items-center gap-2">
                                        <a href="{{ path('category_template_edit', {id: tpl.id}) }}" class="btn btn-sm btn-outline-primary py-0 px-1">
                                            <i class="fa-solid fa-pen"></i>
                                        </a>
                                        <form method="post" action="{{ path('category_template_delete', {id: tpl.id}) }}" class="d-flex"
                                              data-controller="confirm"
                                              data-action="submit->confirm#submit"
                                              data-confirm-message-value="¿Eliminar la plantilla «{{ tpl.name }}»?"
                                              data-confirm-text-value="Eliminar">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ tpl.id) }}">
                                            <button type="submit" class="btn btn-sm btn-outline-danger py-0 px-1">
                                                <i class="fa-solid fa-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </li>
                            {% endfor %}
                        </ul>
                    </div>
                </div>
            {% endif %}
        </div>
    {% endif %}

{# ── Vista: categorías de cuenta ─────────────────────────────────────────── #}
{% else %}

    {% set expenses = categories|filter(c => c.type == 'expense') %}
    {% set incomes  = categories|filter(c => c.type == 'income') %}

    {% if categories is empty %}
        <div class="text-center py-5">
            <i class="fa-solid fa-tags fa-3x text-muted mb-3"></i>
            <h5 class="text-muted">Esta cuenta no tiene categorías</h5>
            {% if is_granted('ACCOUNT_EDIT', currentAccount) %}
                <a href="{{ path('category_create', {account: currentAccount.id}) }}" class="btn btn-primary mt-2">
                    <i class="fa-solid fa-plus me-1"></i>Crear categoría
                </a>
            {% endif %}
        </div>
    {% else %}
        <div class="row g-3"
             data-tour-step="3"
             data-tour-title="Gastos e ingresos"
             data-tour-text="Tus categorías, separadas por tipo. Al crear movimientos podrás asignarles una categoría y así ver en qué se te va el dinero."
             data-tour-side="top">
            {% if expenses is not empty %}
                <div class="col-12 col-md-6">
                    <div class="card shadow border">
                        <div class="card-header bg-body-tertiary border-bottom">
                            <h6 class="mb-0 text-danger"><i class="fa-solid fa-arrow-trend-down me-2"></i>Gastos</h6>
                        </div>
                        <ul class="list-group list-group-flush">
                            {% for cat in expenses %}
                                <li class="list-group-item d-flex align-items-center justify-content-between">
                                    <div class="d-flex align-items-center gap-2">
                                        {% if cat.color %}
                                            <span class="rounded-circle d-inline-block" style="width:12px;height:12px;background:{{ cat.color }}"></span>
                                        {% endif %}
                                        <span>{{ cat.name }}</span>
                                    </div>
                                    {% if is_granted('ACCOUNT_EDIT', currentAccount) %}
                                        <div class="d-flex align-items-center gap-2">
                                            <a href="{{ path('category_edit', {id: cat.id}) }}" class="btn btn-sm btn-outline-primary py-0 px-1">
                                                <i class="fa-solid fa-pen"></i>
                                            </a>
                                            <form method="post" action="{{ path('category_delete', {id: cat.id}) }}" class="d-flex"
                                                  data-controller="confirm"
                                                  data-action="submit->confirm#submit"
                                                  data-confirm-message-value="¿Eliminar la categoría «{{ cat.name }}»?"
                                                  data-confirm-text-value="Eliminar">
                                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ cat.id) }}">
                                                <button type="submit" class="btn btn-sm btn-outline-danger py-0 px-1">
                                                    <i class="fa-solid fa-trash"></i>
                                                </button>
                                            </form>
                                        </div>
                                    {% endif %}
                                </li>
                            {% endfor %}
                        </ul>
                    </div>
                </div>
            {% endif %}

            {% if incomes is not empty %}
                <div class="col-12 col-md-6">
                    <div class="card shadow border">
                        <div class="card-header bg-body-tertiary border-bottom">
                            <h6 class="mb-0 text-success"><i class="fa-solid fa-arrow-trend-up me-2"></i>Ingresos</h6>
                        </div>
                        <ul class="list-group list-group-flush">
                            {% for cat in incomes %}
                                <li class="list-group-item d-flex align-items-center justify-content-between">
                                    <div class="d-flex align-items-center gap-2">
                                        {% if cat.color %}
                                            <span class="rounded-circle d-inline-block" style="width:12px;height:12px;background:{{ cat.color }}"></span>
                                        {% endif %}
                                        <span>{{ cat.name }}</span>
                                    </div>
                                    {% if is_granted('ACCOUNT_EDIT', currentAccount) %}
                                        <div class="d-flex align-items-center gap-2">
                                            <a href="{{ path('category_edit', {id: cat.id}) }}" class="btn btn-sm btn-outline-primary py-0 px-1">
                                                <i class="fa-solid fa-pen"></i>
                                            </a>
                                            <form method="post" action="{{ path('category_delete', {id: cat.id}) }}" class="d-flex"
                                                  data-controller="confirm"
                                                  data-action="submit->confirm#submit"
                                                  data-confirm-message-value="¿Eliminar la categoría «{{ cat.name }}»?"
                                                  data-confirm-text-value="Eliminar">
                                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ cat.id) }}">
                                                <button type="submit" class="btn btn-sm btn-outline-danger py-0 px-1">
                                                    <i class="fa-solid fa-trash"></i>
                                                </button>
                                            </form>
                                        </div>
                                    {% endif %}
                                </li>
                            {% endfor %}
                        </ul>
                    </div>
                </div>
            {% endif %}
        </div>
    {% endif %}

{% endif %}

</div> {# /tour #}
{% endblock %}

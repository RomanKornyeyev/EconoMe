{% extends 'base.html.twig' %}

{% block title %}{{ isTemplateView ? 'Nueva categoría (mi plantilla)' : 'Nueva categoría' }}{% endblock %}

{% block content %}
<div class="row justify-content-center">
    <div class="col-12 col-md-6 col-lg-4">
        <div class="d-flex align-items-center gap-2 mb-4">
            {% if isTemplateView %}
                <a href="{{ path('category_index', {template: 'true'}) }}" class="btn btn-sm btn-outline-secondary">
                    <i class="fa-solid fa-arrow-left"></i>
                </a>
                <h4 class="mb-0">Nueva categoría (mi plantilla)</h4>
            {% else %}
                <a href="{{ path('category_index', {account: account.id}) }}" class="btn btn-sm btn-outline-secondary">
                    <i class="fa-solid fa-arrow-left"></i>
                </a>
                <h4 class="mb-0">Nueva categoría</h4>
            {% endif %}
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                {{ form_start(form) }}
                    {{ form_row(form.name) }}
                    {{ form_row(form.type) }}
                    {{ form_row(form.icon) }}
                    {{ form_row(form.color) }}
                    <div class="d-flex gap-2 mt-3">
                        <button type="submit" class="btn btn-primary">
                            <i class="fa-solid fa-check me-1"></i>Crear
                        </button>
                        {% if isTemplateView %}
                            <a href="{{ path('category_index', {template: 'true'}) }}" class="btn btn-outline-secondary">Cancelar</a>
                        {% else %}
                            <a href="{{ path('category_index', {account: account.id}) }}" class="btn btn-outline-secondary">Cancelar</a>
                        {% endif %}
                    </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}

{# Página 500 autónoma a propósito: NO extiende base.html.twig porque el header
   consulta la BD (pending_friend_requests_count, etc.) y si el error viene de
   una caída de BD, la propia página de error fallaría. #}
<!DOCTYPE html>
<html lang="es" data-bs-theme="light">
	<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1">
		<title>Error interno - {{ app_name|default('EconoMe') }}</title>
		<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
		<script>
			// Respeta el tema guardado por color_mode.js sin depender de assets locales
			(() => {
				const theme = localStorage.getItem('theme');
				const dark = window.matchMedia('(prefers-color-scheme: dark)').matches;
				document.documentElement.setAttribute('data-bs-theme',
					theme === 'light' || theme === 'dark' ? theme : (dark ? 'dark' : 'light'));
			})();
		</script>
	</head>
	<body class="bg-body">
		<div class="min-vh-100 d-flex flex-column align-items-center justify-content-center text-center px-3">
			<h1 class="display-1 fw-bold">500</h1>
			<h2 class="fs-3 mb-3">Algo ha salido mal</h2>
			<p class="text-body-secondary mb-4" style="max-width: 32rem;">
				Ha ocurrido un error inesperado en el servidor. Ya estamos al tanto.
				Puedes reintentarlo en unos minutos.
			</p>
			<div class="d-flex gap-2">
				<button type="button" class="btn btn-primary" onclick="location.reload()">Reintentar</button>
				<a href="/" class="btn btn-outline-primary">Volver al inicio</a>
			</div>
		</div>
	</body>
</html>

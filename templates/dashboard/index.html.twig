{% extends 'base.html.twig' %}

{% block title %}Dashboard{% endblock %}

{% block content %}
{% if not hasAccounts %}
    <div class="text-center py-5">
        <h4>No tienes ninguna cuenta</h4>
        <p class="text-muted">Crea tu primera cuenta para empezar a registrar movimientos.</p>
        <a href="{{ path('account_create') }}" class="btn btn-primary">Crear cuenta</a>
    </div>
{% else %}

{# Header con selector de cuenta y mes #}
<div class="d-flex flex-wrap justify-content-between align-items-center mb-3 gap-2">
    <h4 class="mb-0">Dashboard</h4>
    <div class="d-flex gap-2 flex-wrap">
        <select class="form-select form-select-sm" style="width:auto" onchange="window.location.href='?account='+this.value+'&year={{ year }}&month={{ month }}'">
            {% for acc in accounts %}
                <option value="{{ acc.id }}" {{ acc.id == currentAccount.id ? 'selected' : '' }}>{{ acc.name }}</option>
            {% endfor %}
        </select>
        <select class="form-select form-select-sm" style="width:auto" onchange="let v=this.value.split('-'); window.location.href='?account={{ currentAccount.id }}&year='+v[0]+'&month='+v[1]">
            {% for m in 1..12 %}
                <option value="{{ year }}-{{ m }}" {{ m == month ? 'selected' : '' }}>
                    {{ (year ~ '-' ~ m|format_number({fraction_digit: 0}) ~ '-01')|date('F Y') }}
                </option>
            {% endfor %}
        </select>
        <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#newTransactionModal">
            <i class="fa-solid fa-plus me-1"></i>Nuevo movimiento
        </button>
    </div>
</div>

{# Stats cards #}
{% include 'components/_stats_cards.html.twig' %}

{# Charts #}
<div class="row g-3 mb-3">
    <div class="col-12 col-lg-8">
        {% include 'components/_chart_bar.html.twig' %}
    </div>
    <div class="col-12 col-lg-4">
        {% include 'components/_chart_doughnut.html.twig' %}
    </div>
</div>

{# Últimos movimientos #}
<div class="card border-0 shadow-sm">
    <div class="card-header bg-transparent d-flex justify-content-between align-items-center">
        <h6 class="mb-0">Últimos movimientos</h6>
        <a href="{{ path('transaction_index', {account: currentAccount.id}) }}" class="btn btn-sm btn-outline-secondary">Ver todos</a>
    </div>

    {# Tabla desktop: visible en md+ #}
    <div class="d-none d-md-block">
        {% include 'transaction/_table_desktop.html.twig' %}
    </div>

    {# Cards mobile: visible en < md #}
    <div class="d-md-none">
        {% include 'transaction/_cards_mobile.html.twig' %}
    </div>
</div>

<div class="mt-3 d-flex justify-content-center">
    {{ knp_pagination_render(transactions) }}
</div>

{% include 'transaction/_modal_create.html.twig' %}

{% endif %}
{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}Dashboard{% endblock %}

{% block content %}
{% if not hasAccounts %}
    {% include 'partials/_no_account.html.twig' with {message: 'Crea tu primera cuenta para empezar a visualizar las métricas.'} %}
{% else %}

{% import 'partials/macros/_tour.html.twig' as tour %}
{% set q = app.request.query.all %}

<div {{ tour.attrs('dashboard') }}>

{# Zona 1: Cabecera — título + selector de cuenta #}
<div class="d-flex flex-wrap justify-content-between gap-2">
    <div class="d-flex flex-wrap justify-content-start align-items-center mb-3 gap-2">
        <h1 class="h2 mb-0">Dashboard</h1>
        {% include 'partials/_account_selector.html.twig' with {
            accounts: accounts,
            current: currentAccount,
            menuEnd: true,
            tourStep: 1,
            tourTitle: 'Selector de cuenta',
            tourText: 'Todo lo que ves en el dashboard pertenece a la cuenta seleccionada. Cambia de cuenta desde aquí.',
        } only %}

        {# Zona 2: Filtros globales #}
        {% if month == 0 %}
            {% set prevUrl = '?' ~ q|merge({'year': year - 1, 'month': 0})|url_encode %}
            {% set nextUrl = '?' ~ q|merge({'year': year + 1, 'month': 0})|url_encode %}
        {% else %}
            {% if month == 1 %}{% set prevYear = year - 1 %}{% set prevMonth = 12 %}
            {% else %}{% set prevYear = year %}{% set prevMonth = month - 1 %}{% endif %}
            {% if month == 12 %}{% set nextYear = year + 1 %}{% set nextMonth = 1 %}
            {% else %}{% set nextYear = year %}{% set nextMonth = month + 1 %}{% endif %}
            {% set prevUrl = '?' ~ q|merge({'year': prevYear, 'month': prevMonth})|url_encode %}
            {% set nextUrl = '?' ~ q|merge({'year': nextYear, 'month': nextMonth})|url_encode %}
        {% endif %}
        {% set monthNames = ['Enero','Febrero','Marzo','Abril','Mayo','Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'] %}
        <div class="btn-group" role="group"
             data-tour-step="2"
             data-tour-title="Filtra por período"
             data-tour-text="Navega mes a mes o consulta el año completo. Los meses sin datos aparecen atenuados.">
            <a href="{{ prevUrl }}" class="btn btn-sm btn-outline-primary" style="padding-left: 0.75rem; padding-right: 0.75rem;"><i class="fa-solid fa-chevron-left fa-sm"></i></a>

            {# Desplegable de mes #}
            <div class="btn-group" role="group">
                <button type="button" class="btn btn-sm btn-outline-primary dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
                    {% if month == 0 %}Año completo{% else %}{{ monthNames[month - 1] }}{% endif %}
                </button>
                <ul class="dropdown-menu">
                    {% for m in 1..12 %}
                        {% set hasData = m in availableMonths %}
                        <li>
                            <a class="dropdown-item {{ m == month ? 'active' : '' }}" href="?{{ q|merge({'month': m})|url_encode }}">
                                {% if not hasData %}
                                    <span class="text-muted">{{ monthNames[m - 1] }}</span>
                                {% else %}
                                    {{ monthNames[m - 1] }}
                                {% endif %}
                                {% if not hasData %}<span class="ms-1" style="font-size:.72em; opacity:.4">(sin datos)</span>{% endif %}
                            </a>
                        </li>
                    {% endfor %}
                    <li><hr class="dropdown-divider"></li>
                    <li><a class="dropdown-item {{ month == 0 ? 'active' : '' }}" href="?{{ q|merge({'month': 0})|url_encode }}">Año completo</a></li>
                </ul>
            </div>

            {# Desplegable de año #}
            <div class="btn-group" role="group">
                <button type="button" class="btn btn-sm btn-outline-primary dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
                    {{ year }}
                </button>
                <ul class="dropdown-menu">
                    {% for y in availableYears %}
                        <li><a class="dropdown-item {{ y == year ? 'active' : '' }}" href="?{{ q|merge({'year': y})|url_encode }}">{{ y }}</a></li>
                    {% endfor %}
                </ul>
            </div>

            <a href="{{ nextUrl }}" class="btn btn-sm btn-outline-primary" style="padding-left: 0.75rem; padding-right: 0.75rem;"><i class="fa-solid fa-chevron-right fa-sm"></i></a>
        </div>
    </div>


    <div class="d-flex flex-wrap justify-content-end align-items-center mb-3 gap-2 bg-body">
        <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#newTransactionModal"
                data-tour-step="6"
                data-tour-title="Añade movimientos"
                data-tour-text="Registra un gasto o un ingreso sin salir del dashboard.">
            <i class="fa-solid fa-plus me-1"></i>Nuevo movimiento
        </button>
        {{ tour.help_button() }}
    </div>
</div>





{# Zona 3: KPIs #}
{% include 'components/_stats_cards.html.twig' %}

{# Zona 4: Gráficos #}
<div class="row g-3 mb-3"
     data-tour-step="4"
     data-tour-title="Tus gráficos"
     data-tour-text="Evolución mensual de ingresos y gastos del año, y reparto por categorías del período seleccionado."
     data-tour-side="top">
    <div class="col-12 col-lg-8">
        {% include 'components/_chart_bar.html.twig' %}
    </div>
    <div class="col-12 col-lg-4">
        {% include 'components/_chart_doughnut.html.twig' %}
    </div>
</div>

{# Zona 5: Movimientos #}
<div class="card border shadow-sm" id="table_transactions" data-controller="bulk-select"
     data-tour-step="5"
     data-tour-title="Movimientos del período"
     data-tour-text="Los movimientos de la cuenta en el período seleccionado. Desde «Ver todos» accedes al listado completo con filtros avanzados."
     data-tour-side="top">
    <div class="card-header bg-body-tertiary border-bottom d-flex align-items-center">
        {# Estado normal #}
        <div data-bulk-select-target="normalBar" class="d-flex justify-content-between align-items-center w-100">
            <h5 class="mb-0">Movimientos <span class="text-muted fw-normal small">{{ periodLabel }}</span></h5>
            <a href="{{ path('transaction_index', {account: currentAccount.id}) }}"
               class="btn btn-sm btn-outline-secondary">Ver todos</a>
        </div>
        {# Estado bulk #}
        {% include 'transaction/_table_bulk_bar.html.twig' %}
    </div>

    {# Tabla desktop: visible en md+ #}
    <div class="d-none d-md-block">
        {% include 'transaction/_table_desktop.html.twig' %}
    </div>

    {# Cards mobile: visible en < md #}
    <div class="d-md-none">
        {% include 'transaction/_cards_mobile.html.twig' %}
    </div>
</div>

<div class="mt-3 d-flex justify-content-center">
    {{ knp_pagination_render(transactions) }}
</div>

{% include 'transaction/_modal_create.html.twig' %}
{% include 'transaction/_modal_summary.html.twig' %}

</div> {# /tour #}

{% endif %}
{% endblock %}
